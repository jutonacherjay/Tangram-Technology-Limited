<script>
(function(){
  var isMobile = function(){ return window.innerWidth <= 640; };
  var track = document.getElementById('tngTrack');
  var slides = Array.from(track.querySelectorAll('.tng-slide'));
  var total = slides.length;
  var current = 0;
  var autoTimer;
  var visible, pages;

  var dotsEl = document.getElementById('tngDots');

  function getVisible(){ return isMobile() ? 2 : 3; }

  function buildDots(){
    dotsEl.innerHTML = '';
    pages = Math.ceil(total / visible);
    for(var i = 0; i < pages; i++){
      var d = document.createElement('button');
      d.className = 'tng-dot' + (i === 0 ? ' active' : '');
      (function(idx){ d.addEventListener('click', function(){ goTo(idx); }); })(i);
      dotsEl.appendChild(d);
    }
  }

  function updateActive(){
    var start = current * visible;
    slides.forEach(function(s, i){
      s.classList.toggle('active', i >= start && i < start + visible);
    });
  }

  function getSlideWidth(){
    return slides[0].getBoundingClientRect().width;
  }

  function goTo(page){
    pages = Math.ceil(total / visible);
    current = (page + pages) % pages;
    track.style.transform = 'translateX(-' + (current * visible * getSlideWidth()) + 'px)';
    var dots = dotsEl.querySelectorAll('.tng-dot');
    dots.forEach(function(d, i){ d.classList.toggle('active', i === current); });
    slides.forEach(function(s){ s.classList.remove('active'); });
    setTimeout(updateActive, 80);
    clearInterval(autoTimer);
    autoTimer = setInterval(function(){ goTo(current + 1); }, 6000);
  }

  function init(){
    visible = getVisible();
    pages = Math.ceil(total / visible);
    if(current >= pages) current = 0;
    buildDots();
    track.style.transition = 'none';
    track.style.transform = 'translateX(-' + (current * visible * getSlideWidth()) + 'px)';
    setTimeout(function(){ track.style.transition = 'transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94)'; }, 50);
    updateActive();
  }

  document.getElementById('tngPrev').addEventListener('click', function(){ goTo(current - 1); });
  document.getElementById('tngNext').addEventListener('click', function(){ goTo(current + 1); });

  var resizeTimer;
  window.addEventListener('resize', function(){
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function(){
      visible = getVisible();
      init();
    }, 150);
  });

  init();
  autoTimer = setInterval(function(){ goTo(current + 1); }, 3000);
})();
</script>
