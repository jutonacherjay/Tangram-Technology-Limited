<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Product Catalog</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap');

#flipbook-widget {
  --fb-teal:#2ecfb0;
  --fb-deep-teal:#0a9e84;
  --fb-dark-teal:#077d68;
  --fb-near-black:#0d1f1b;
  --fb-label-grey:#aaa;
  --fb-dot-off:#cde8e4;
  --fb-badge-bg:rgba(46,207,176,0.12);
  --fb-badge-bd:rgba(46,207,176,0.35);
  --fb-counter-bg:rgba(10,158,132,0.82);
  --fb-page-l:#f5fdfb;
  --fb-page-r:#edfaf6;
  --fb-mint:#e8f8f5;
  --fb-lteal:#c8f2ec;

  width:100%;
  display:flex; flex-direction:column; align-items:center;
  background:#fff;
  font-family:'DM Sans',sans-serif;
  -webkit-font-smoothing:antialiased;
  user-select:none;
  padding:14px 8px 22px;
}
#flipbook-widget *, #flipbook-widget *::before, #flipbook-widget *::after {
  box-sizing:border-box; margin:0; padding:0;
}

/* Header */
#flipbook-widget .fb-header {
  display:flex; flex-direction:column; align-items:center;
  margin-bottom:14px; gap:5px; text-align:center;
}
#flipbook-widget .fb-eyebrow {
  display:inline-flex; align-items:center; gap:5px;
  background:var(--fb-badge-bg); border:1px solid var(--fb-badge-bd);
  border-radius:20px; padding:3px 12px;
  font-size:0.65rem; font-weight:700; color:var(--fb-deep-teal);
  letter-spacing:0.14em; text-transform:uppercase;
}
#flipbook-widget .fb-title {
  font-family:'DM Serif Display',serif;
  font-size:clamp(1.2rem,4vw,1.9rem);
  color:var(--fb-near-black); font-weight:400;
}
#flipbook-widget .fb-tagline {
  font-size:clamp(0.65rem,2vw,0.78rem); color:var(--fb-label-grey);
}

/* Scene */
#flipbook-widget .fb-scene-wrap { width:100%; display:flex; justify-content:center; }
#flipbook-widget .fb-scene {
  position:relative; flex-shrink:0;
  /* perspective set by JS */
}
#flipbook-widget .fb-scene::after {
  content:''; position:absolute; bottom:-16px; left:5%; width:90%; height:20px;
  background:radial-gradient(ellipse,rgba(7,125,104,0.22) 0%,transparent 70%);
  filter:blur(8px); pointer-events:none;
}

/* Book */
#flipbook-widget .fb-book {
  width:100%; height:100%; position:relative;
  transform-style:preserve-3d;
  -webkit-transform-style:preserve-3d;
}
/* Page-stack edge */
#flipbook-widget .fb-book::before {
  content:''; position:absolute; right:-5px; top:2px;
  width:7px; height:calc(100% - 4px);
  background:repeating-linear-gradient(to bottom,#cfe9e4 0,#cfe9e4 1px,#e4f7f3 1px,#e4f7f3 3px);
  border-radius:0 2px 2px 0;
}

/* Static left / right pages */
#flipbook-widget .fb-sl,
#flipbook-widget .fb-sr {
  position:absolute; top:0; width:50%; height:100%; overflow:hidden; z-index:1;
}
#flipbook-widget .fb-sl { left:0;  border-radius:4px 0 0 4px; background:var(--fb-page-l); }
#flipbook-widget .fb-sr { right:0; border-radius:0 4px 4px 0; background:var(--fb-page-r); }
#flipbook-widget .fb-sl::after {
  content:''; position:absolute; top:0; right:0; width:32px; height:100%;
  background:linear-gradient(to right,transparent,rgba(0,0,0,0.055));
  pointer-events:none; z-index:5;
}
#flipbook-widget .fb-sr::before {
  content:''; position:absolute; top:0; left:0; width:32px; height:100%;
  background:linear-gradient(to right,rgba(0,0,0,0.055),transparent);
  pointer-events:none; z-index:5;
}

/* Spine */
#flipbook-widget .fb-spine {
  position:absolute; left:calc(50% - 9px); top:0;
  width:18px; height:100%; z-index:200; pointer-events:none;
  background:linear-gradient(to right,#055e4e,var(--fb-dark-teal) 20%,#0eb898 50%,var(--fb-dark-teal) 80%,#055e4e);
  box-shadow:-3px 0 8px rgba(0,0,0,0.18),3px 0 8px rgba(0,0,0,0.18),0 0 18px rgba(10,158,132,0.28);
}
#flipbook-widget .fb-spine::after {
  content:'CATALOG 2025'; writing-mode:vertical-rl;
  font-size:0.38rem; letter-spacing:0.28em; font-weight:600;
  color:rgba(255,255,255,0.38);
  position:absolute; top:50%; left:50%;
  transform:translate(-50%,-50%) rotate(180deg); white-space:nowrap;
}

/* ── THE FLIP CARD ──────────────────────────────── */
/* flip-card wraps front+back, positioned on right half
   transform-style:preserve-3d so children can 3D rotate  */
#flipbook-widget .fb-card {
  position:absolute; top:0; left:50%; width:50%; height:100%;
  transform-origin:left center;
  transform-style:preserve-3d;
  -webkit-transform-style:preserve-3d;
  z-index:50;
  /* transition is set/removed by JS */
}
#flipbook-widget .fb-card-front,
#flipbook-widget .fb-card-back {
  position:absolute; top:0; left:0; width:100%; height:100%;
  backface-visibility:hidden;
  -webkit-backface-visibility:hidden;
  overflow:hidden;
}
#flipbook-widget .fb-card-front { border-radius:0 4px 4px 0; }
#flipbook-widget .fb-card-front::before {
  content:''; position:absolute; top:0; left:0; width:28px; height:100%; z-index:10;
  background:linear-gradient(to right,rgba(0,0,0,0.12),transparent); pointer-events:none;
}
#flipbook-widget .fb-card-back {
  border-radius:4px 0 0 4px;
  transform:rotateY(180deg);
}
#flipbook-widget .fb-card-back::after {
  content:''; position:absolute; top:0; right:0; width:28px; height:100%; z-index:10;
  background:linear-gradient(to left,rgba(0,0,0,0.12),transparent); pointer-events:none;
}

/* Book frame overlay */
#flipbook-widget .fb-frame {
  position:absolute; inset:0; z-index:300; border-radius:4px; pointer-events:none;
  box-shadow:inset 0 0 0 1px rgba(10,158,132,0.14),
    0 10px 36px rgba(7,125,104,0.18), 0 3px 10px rgba(13,31,27,0.1);
}

/* Controls */
#flipbook-widget .fb-controls {
  display:flex; align-items:center; justify-content:center;
  gap:12px; margin-top:16px; flex-wrap:wrap;
}
#flipbook-widget .fb-btn {
  background:var(--fb-deep-teal); border:none; color:#fff;
  padding:10px 24px; font-family:'DM Sans',sans-serif;
  font-size:clamp(0.68rem,2vw,0.82rem); font-weight:600;
  letter-spacing:0.06em; text-transform:uppercase;
  cursor:pointer; border-radius:7px; line-height:1;
  transition:background 0.2s, transform 0.1s, box-shadow 0.2s;
  box-shadow:0 4px 14px rgba(10,158,132,0.28);
}
#flipbook-widget .fb-btn:hover:not([disabled]) {
  background:var(--fb-dark-teal); transform:translateY(-2px);
  box-shadow:0 6px 18px rgba(10,158,132,0.38);
}
#flipbook-widget .fb-btn[disabled] {
  opacity:0.45; cursor:not-allowed; transform:none; box-shadow:none;
}
#flipbook-widget .fb-dots { display:flex; gap:6px; align-items:center; }
#flipbook-widget .fb-dot {
  width:8px; height:8px; border-radius:50%;
  background:var(--fb-dot-off); cursor:pointer;
  transition:background 0.3s, transform 0.3s;
}
#flipbook-widget .fb-dot.on { background:var(--fb-teal); transform:scale(1.4); }
#flipbook-widget .fb-counter {
  background:var(--fb-counter-bg); color:#fff; font-weight:600;
  font-size:clamp(0.65rem,2vw,0.75rem);
  padding:5px 14px; border-radius:20px; min-width:72px; text-align:center;
}
#flipbook-widget .fb-hint {
  font-size:0.6rem; color:var(--fb-label-grey);
  margin-top:6px; text-align:center;
}

/* Photo / blank page content */
#flipbook-widget .fb-photo {
  width:100%; height:100%; overflow:hidden;
  background:#fff;
}
#flipbook-widget .fb-photo img {
  width:100%; height:100%;
  object-fit:cover;
  display:block;
}
#flipbook-widget .fb-blank {
  width:100%; height:100%;
  background:linear-gradient(135deg,var(--fb-lteal),var(--fb-mint));
}

/* ── Responsive breakpoints ── */

/* Large desktop 1200px+ */
@media (min-width:1200px) {
  #flipbook-widget { padding:20px 16px 28px; }
  #flipbook-widget .fb-header { margin-bottom:18px; gap:7px; }
}

/* Laptop / small desktop 900–1199px */
@media (max-width:1199px) and (min-width:901px) {
  #flipbook-widget { padding:16px 12px 22px; }
}

/* Tablet landscape 768–900px */
@media (max-width:900px) and (min-width:601px) {
  #flipbook-widget { padding:12px 8px 18px; }
  #flipbook-widget .fb-header { margin-bottom:10px; gap:4px; }
  #flipbook-widget .fb-controls { gap:10px; margin-top:12px; }
  #flipbook-widget .fb-btn { padding:8px 18px; }
}

/* Mobile landscape */
@media (max-width:767px) and (orientation:landscape) {
  #flipbook-widget { padding:6px 8px 10px; }
  #flipbook-widget .fb-header { margin-bottom:6px; gap:3px; }
  #flipbook-widget .fb-tagline { display:none; }
  #flipbook-widget .fb-controls { margin-top:8px; gap:8px; }
  #flipbook-widget .fb-btn { padding:7px 14px; font-size:0.7rem; }
  #flipbook-widget .fb-hint { display:none; }
}

/* Mobile portrait ≤600px */
@media (max-width:600px) {
  #flipbook-widget { padding:10px 6px 16px; }
  #flipbook-widget .fb-header { margin-bottom:10px; gap:4px; }
  #flipbook-widget .fb-title  { font-size:1.15rem; }
  #flipbook-widget .fb-tagline{ font-size:0.62rem; }
  #flipbook-widget .fb-controls{ gap:8px; margin-top:10px; flex-wrap:nowrap; }
  #flipbook-widget .fb-btn { padding:8px 14px; font-size:0.7rem; letter-spacing:0.03em; }
  #flipbook-widget .fb-dot { width:6px; height:6px; }
  #flipbook-widget .fb-counter{ min-width:58px; padding:4px 10px; font-size:0.68rem; }
  #flipbook-widget .fb-hint { font-size:0.58rem; margin-top:5px; }
  /* Thinner spine on mobile */
  #flipbook-widget .fb-spine { width:12px; left:calc(50% - 6px); }
}

/* Very small phones ≤380px */
@media (max-width:380px) {
  #flipbook-widget { padding:8px 4px 14px; }
  #flipbook-widget .fb-eyebrow { display:none; }
  #flipbook-widget .fb-title  { font-size:1rem; }
  #flipbook-widget .fb-tagline{ display:none; }
  #flipbook-widget .fb-btn { padding:7px 10px; font-size:0.63rem; }
  #flipbook-widget .fb-counter{ min-width:50px; padding:4px 8px; font-size:0.62rem; }
  #flipbook-widget .fb-dots { gap:4px; }
  #flipbook-widget .fb-dot { width:5px; height:5px; }
}
</style>
</head>
<body>

<div id="flipbook-widget">

  <div class="fb-header">
    <div class="fb-eyebrow">✦ &nbsp;2026 Collection</div>
    <div class="fb-title">Product Catalog</div>
    <div class="fb-tagline">Flip through to explore our curated range</div>
  </div>

  <div class="fb-scene-wrap">
    <div class="fb-scene" id="fbScene">
      <div class="fb-book">
        <div class="fb-sl" id="fbSL"></div>
        <div class="fb-sr" id="fbSR"></div>

        <!-- The 3D flip card -->
        <div class="fb-card" id="fbCard">
          <div class="fb-card-front" id="fbFront"></div>
          <div class="fb-card-back"  id="fbBack"></div>
        </div>

        <div class="fb-spine"></div>
        <div class="fb-frame"></div>
      </div>
    </div>
  </div>

  <div class="fb-controls">
    <button class="fb-btn" id="fbPrev">&#8592; Prev</button>
    <div class="fb-dots" id="fbDots"></div>
    <div class="fb-counter" id="fbCount"></div>
    <button class="fb-btn" id="fbNext">Next &#8594;</button>
  </div>
  <div class="fb-hint">← Swipe or use arrow keys →</div>

</div>

<script>
/* ─────────────────────────────────────────────────────
   IMAGES  — swap these URLs for your own
───────────────────────────────────────────────────── */
var IMGS = [
  'https://tangramelectronics.com/wp-content/uploads/2026/03/Tangram-Switch-Socket-Catalog-2026_page-0001.jpg',
  'https://tangramelectronics.com/wp-content/uploads/2026/03/Tangram-Switch-Socket-Catalog-2026_page-0002.jpg',
  'https://tangramelectronics.com/wp-content/uploads/2026/03/Tangram-Switch-Socket-Catalog-2026_page-0003.jpg',
  'https://tangramelectronics.com/wp-content/uploads/2026/03/Tangram-Switch-Socket-Catalog-2026_page-0004.jpg',
  'https://tangramelectronics.com/wp-content/uploads/2026/03/Tangram-Switch-Socket-Catalog-2026_page-0005.jpg',
  'https://tangramelectronics.com/wp-content/uploads/2026/03/Tangram-Switch-Socket-Catalog-2026_page-0006.jpg',
  'https://tangramelectronics.com/wp-content/uploads/2026/03/Tangram-Switch-Socket-Catalog-2026_page-0007.jpg',
  'https://tangramelectronics.com/wp-content/uploads/2026/03/Tangram-Switch-Socket-Catalog-2026_page-0008.jpg',
];

/* 8 images → 4 spreads */
var SPREADS = [
  [IMGS[0], IMGS[1]],
  [IMGS[2], IMGS[3]],
  [IMGS[4], IMGS[5]],
  [IMGS[6], IMGS[7]],
];

/* ─────────────────────────────────────────────────────
   DOM refs
───────────────────────────────────────────────────── */
var scene  = document.getElementById('fbScene');
var card   = document.getElementById('fbCard');
var front  = document.getElementById('fbFront');
var back   = document.getElementById('fbBack');
var sl     = document.getElementById('fbSL');
var sr     = document.getElementById('fbSR');
var prevBtn= document.getElementById('fbPrev');
var nextBtn= document.getElementById('fbNext');
var dotsEl = document.getElementById('fbDots');
var countEl= document.getElementById('fbCount');

/* ─────────────────────────────────────────────────────
   STATE
───────────────────────────────────────────────────── */
var cur  = 0;
var busy = false;
var DUR  = 800; // ms — match CSS transition below

/* ─────────────────────────────────────────────────────
   HELPERS
───────────────────────────────────────────────────── */
function html(url) {
  if (!url) return '<div class="fb-blank"></div>';
  return '<div class="fb-photo"><img src="'+url+'" alt="" loading="lazy"/></div>';
}

function showSpread(i) {
  sl.innerHTML = html(SPREADS[i][0]);
  sr.innerHTML = html(SPREADS[i][1]);
  updateUI(i);
}

function updateUI(i) {
  countEl.textContent = (i+1)+' / '+SPREADS.length;
  prevBtn.disabled = (i === 0);
  nextBtn.disabled = (i === SPREADS.length-1);
  dotsEl.innerHTML = '';
  SPREADS.forEach(function(_,k){
    var d = document.createElement('div');
    d.className = 'fb-dot' + (k===i ? ' on' : '');
    dotsEl.appendChild(d);
  });
}

/* ─────────────────────────────────────────────────────
   SIZING
───────────────────────────────────────────────────── */
function resize() {
  var vw = window.innerWidth;
  var vh = window.innerHeight;
  var isLandscape = vw > vh;

  /* Measure chrome heights */
  var widget = document.getElementById('flipbook-widget');
  var hdrH   = (widget.querySelector('.fb-header')   || {offsetHeight:60}).offsetHeight;
  var ctlH   = (widget.querySelector('.fb-controls') || {offsetHeight:48}).offsetHeight;
  var hintH  = (widget.querySelector('.fb-hint')     || {offsetHeight:20}).offsetHeight;
  var pad    = 56;
  var availH = vh - hdrH - ctlH - hintH - pad;

  /*
    Dynamically calculate book height from real image ratio.
    Each page = half book width. Image fills one page fully.
    bookH = (bookW / 2) * img_aspect_ratio
    where img_aspect_ratio = imgH / imgW
  */
  var imgRatio = (typeof FB_IMG_RATIO !== 'undefined') ? FB_IMG_RATIO : 1.0;

  var w;
  if (vw >= 1200)      { w = Math.min(vw - 120, 1000); }
  else if (vw >= 1024) { w = Math.min(vw - 80,  880);  }
  else if (vw >= 768)  { w = Math.min(vw - 40,  740);  }
  else if (vw >= 600)  { w = Math.min(vw - 24,  620);  }
  else if (isLandscape){ w = Math.min(vw - 16,  580);  }
  else                 { w = Math.min(vw - 12,  440);  }

  /* Height = half-page-width × image aspect ratio */
  var pageW = w / 2;
  var h = Math.round(pageW * imgRatio);

  /* Clamp height to available space */
  h = Math.min(h, availH, 820);
  h = Math.max(h, 160);
  w = Math.max(Math.round(w), 260);

  scene.style.width       = w + 'px';
  scene.style.height      = h + 'px';
  scene.style.perspective = (w * 2.5) + 'px';

  /* Reset & re-render */
  cur = 0; busy = false;
  card.style.transition = 'none';
  card.style.transform  = 'rotateY(0deg)';
  card.style.zIndex     = '-1';
  front.innerHTML = back.innerHTML = '';
  showSpread(0);
}

/* ─────────────────────────────────────────────────────
   FLIP  — pure JS transition, no CSS animation classes
───────────────────────────────────────────────────── */
function flip(dir) {
  if (busy) return;
  var nxt = cur + dir;
  if (nxt < 0 || nxt >= SPREADS.length) return;
  busy = true;

  /* ── FORWARD (dir = +1) ────────────────────────────
     Card on RIGHT half, rotates LEFT (0 → -180deg).
     front = current RIGHT page (flips away)
     back  = next    LEFT  page (comes in from back)
     Static LEFT stays as current left.
     Static RIGHT shows next right — but only AFTER flip,
     so no blink. During flip the card covers right half.
  ───────────────────────────────────────────────────*/
  if (dir > 0) {
    front.innerHTML = html(SPREADS[cur][1]);
    back.innerHTML  = html(SPREADS[nxt][0]);

    /* Card covers RIGHT half — keep staticRight as-is (hidden under card) */
    card.style.transition     = 'none';
    card.style.left           = '50%';
    card.style.width          = '50%';
    card.style.transformOrigin= 'left center';
    card.style.transform      = 'rotateY(0deg)';
    card.style.zIndex         = '50';

    /* At the exact midpoint (card is edge-on, nothing visible),
       swap the static RIGHT so it's ready when back face appears */
    setTimeout(function(){
      sr.innerHTML = html(SPREADS[nxt][1]);
    }, DUR / 2);

    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        card.style.transition = 'transform '+DUR+'ms cubic-bezier(0.645,0.045,0.355,1.000)';
        card.style.transform  = 'rotateY(-180deg)';
      });
    });

  /* ── BACKWARD (dir = -1) ───────────────────────────
     Card starts at -180deg on LEFT side, rotates to 0deg.
     front = prev RIGHT page (revealed at end on right side)
     back  = cur  LEFT  page (flips away)
     Static RIGHT stays as current right (no blink — card covers left).
     Static LEFT swapped at midpoint.
  ───────────────────────────────────────────────────*/
  } else {
    front.innerHTML = html(SPREADS[nxt][1]);
    back.innerHTML  = html(SPREADS[cur][0]);

    card.style.transition     = 'none';
    card.style.left           = '50%';
    card.style.width          = '50%';
    card.style.transformOrigin= 'left center';
    card.style.transform      = 'rotateY(-180deg)';
    card.style.zIndex         = '50';

    /* Swap static LEFT at midpoint — card covers it so no blink */
    setTimeout(function(){
      sl.innerHTML = html(SPREADS[nxt][0]);
    }, DUR / 2);

    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        card.style.transition = 'transform '+DUR+'ms cubic-bezier(0.645,0.045,0.355,1.000)';
        card.style.transform  = 'rotateY(0deg)';
      });
    });
  }

  /* After animation finishes — settle & show final spread */
  setTimeout(function(){
    cur = nxt;
    card.style.transition = 'none';
    card.style.transform  = 'rotateY(0deg)';
    card.style.zIndex     = '-1';
    front.innerHTML = back.innerHTML = '';
    showSpread(cur);
    setTimeout(function(){ busy = false; }, 50);
  }, DUR + 40);
}

/* ─────────────────────────────────────────────────────
   EVENTS
───────────────────────────────────────────────────── */
nextBtn.addEventListener('click', function(){ flip(1);  });
prevBtn.addEventListener('click', function(){ flip(-1); });

document.addEventListener('keydown', function(e){
  if (e.key==='ArrowRight') flip(1);
  if (e.key==='ArrowLeft')  flip(-1);
});

/* Touch swipe */
var tx=0, ty=0;
scene.addEventListener('touchstart', function(e){ tx=e.touches[0].clientX; ty=e.touches[0].clientY; }, {passive:true});
scene.addEventListener('touchend',   function(e){
  var dx=e.changedTouches[0].clientX-tx, dy=e.changedTouches[0].clientY-ty;
  if (Math.abs(dx)>Math.abs(dy) && Math.abs(dx)>40) flip(dx<0?1:-1);
}, {passive:true});

/* Resize */
var rt;
window.addEventListener('resize', function(){ clearTimeout(rt); rt=setTimeout(resize,180); });

/* ─────────────────────────────────────────────────────
   INIT — detect real image ratio first, then size book
───────────────────────────────────────────────────── */

/* Image aspect ratio per PAGE (half spread).
   We load first image to measure natural width/height */
var FB_IMG_RATIO = 1.0; /* default square, updated after load */

function initWithRatio(imgW, imgH) {
  /* Each page shows one image. Page width = bookW/2, height = bookH.
     We want: bookH / (bookW/2) = imgH/imgW
     => bookH = bookW * imgH / (imgW * 2)
     Store ratio = imgH / imgW (per single image, not spread) */
  FB_IMG_RATIO = imgH / imgW;
  resize();
}

/* Probe first image */
var probe = new Image();
probe.onload = function() { initWithRatio(probe.naturalWidth, probe.naturalHeight); };
probe.onerror = function() { resize(); }; /* fallback */
probe.src = IMGS[0];
</script>
</body>
</html>
