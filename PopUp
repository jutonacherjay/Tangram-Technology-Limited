<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Popup Banner - Tangram Electronics</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* Popup Overlay */
        .popup-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            z-index: 9999;
            animation: fadeIn 0.3s ease;
        }

        .popup-overlay.active {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* Popup Container - RESPONSIVE */
        .popup-container {
            position: relative;
            max-width: 1200px;
            width: 85%;
            max-height: 90vh;
            border-radius: 15px;
            overflow: hidden;
            animation: slideIn 0.4s ease;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        /* Beautiful Close Button with Advanced Animations */
        .close-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 46px;
            height: 46px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 2px solid rgba(255, 255, 255, 0.25);
            border-radius: 50%;
            cursor: pointer;
            font-size: 26px;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            z-index: 10;
            font-weight: 300;
            line-height: 1;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
            animation: pulseGlow 2s ease-in-out infinite;
        }

        .close-btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .close-btn:hover::before {
            opacity: 1;
        }

        .close-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: rotate(90deg) scale(1.15);
            border-color: rgba(255, 255, 255, 0.5);
            box-shadow: 0 12px 30px rgba(255, 255, 255, 0.2),
                        0 0 30px rgba(255, 255, 255, 0.3);
            animation: none;
        }

        .close-btn:active {
            transform: rotate(90deg) scale(0.95);
            transition: all 0.1s ease;
        }

        /* Pulse Glow Animation */
        @keyframes pulseGlow {
            0%, 100% {
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3),
                            0 0 0 0 rgba(255, 255, 255, 0.4);
            }
            50% {
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3),
                            0 0 20px 5px rgba(255, 255, 255, 0.2);
            }
        }

        /* Banner Image - CLICKABLE */
        .banner-link {
            display: block;
            cursor: pointer;
            transition: transform 0.3s ease;
        }

        .banner-link:hover {
            transform: scale(1.02);
        }

        .banner-image {
            width: 100%;
            height: auto;
            display: block;
            object-fit: cover;
        }

        /* Animations */
        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        @keyframes slideIn {
            from {
                transform: scale(0.8);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        /* Large Desktop (1920px+) */
        @media (min-width: 1920px) {
            .popup-container {
                max-width: 1400px;
                width: 70%;
            }

            .close-btn {
                width: 50px;
                height: 50px;
                font-size: 30px;
                top: 25px;
                right: 25px;
            }
        }

        /* Desktop (1440px - 1919px) */
        @media (min-width: 1440px) and (max-width: 1919px) {
            .popup-container {
                max-width: 1200px;
                width: 75%;
            }

            .close-btn {
                width: 48px;
                height: 48px;
                font-size: 28px;
                top: 22px;
                right: 22px;
            }
        }

        /* Laptop (1024px - 1439px) */
        @media (min-width: 1024px) and (max-width: 1439px) {
            .popup-container {
                max-width: 1000px;
                width: 80%;
            }

            .close-btn {
                width: 46px;
                height: 46px;
                font-size: 26px;
            }
        }

        /* Tablet Landscape (768px - 1023px) */
        @media (min-width: 768px) and (max-width: 1023px) {
            .popup-container {
                max-width: 750px;
                width: 85%;
            }

            .close-btn {
                width: 42px;
                height: 42px;
                font-size: 24px;
                top: 18px;
                right: 18px;
            }
        }

        /* Tablet Portrait (600px - 767px) */
        @media (min-width: 600px) and (max-width: 767px) {
            .popup-container {
                max-width: 600px;
                width: 88%;
                border-radius: 14px;
            }

            .close-btn {
                width: 40px;
                height: 40px;
                top: 16px;
                right: 16px;
                font-size: 22px;
            }
        }

        /* Mobile Large (480px - 599px) */
        @media (min-width: 480px) and (max-width: 599px) {
            .popup-container {
                max-width: 500px;
                width: 90%;
                border-radius: 12px;
            }

            .close-btn {
                width: 38px;
                height: 38px;
                top: 15px;
                right: 15px;
                font-size: 20px;
            }

            .dont-show-container {
                bottom: 12px;
                padding: 7px 13px;
            }

            .dont-show {
                font-size: 11px;
            }
        }

        /* Mobile Medium (375px - 479px) */
        @media (min-width: 375px) and (max-width: 479px) {
            .popup-container {
                max-width: 420px;
                width: 92%;
                border-radius: 10px;
            }

            .close-btn {
                width: 36px;
                height: 36px;
                top: 12px;
                right: 12px;
                font-size: 18px;
            }

            .dont-show-container {
                bottom: 10px;
                padding: 6px 12px;
            }

            .dont-show {
                font-size: 10px;
            }

            .dont-show input {
                width: 12px;
                height: 12px;
            }
        }

        /* Mobile Small (320px - 374px) */
        @media (max-width: 374px) {
            .popup-container {
                max-width: 350px;
                width: 95%;
                border-radius: 8px;
            }

            .close-btn {
                width: 32px;
                height: 32px;
                top: 10px;
                right: 10px;
                font-size: 16px;
            }

            .dont-show-container {
                bottom: 8px;
                padding: 5px 10px;
            }

            .dont-show {
                font-size: 9px;
            }

            .dont-show input {
                width: 11px;
                height: 11px;
            }
        }

        /* Don't Show Again - Simple Checkbox Below Image */
        .dont-show-container {
            position: absolute;
            bottom: 15px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(10px);
            padding: 8px 15px;
            border-radius: 20px;
            z-index: 5;
        }

        .dont-show {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: white;
        }

        .dont-show input {
            cursor: pointer;
            width: 14px;
            height: 14px;
            accent-color: #108981;
        }

        .dont-show label {
            cursor: pointer;
            user-select: none;
        }
    </style>
</head>
<body>

    <!-- Popup Overlay -->
    <div class="popup-overlay" id="popupOverlay">
        <div class="popup-container">
            <!-- Beautiful Animated Close Button -->
            <button class="close-btn" id="closeBtn" aria-label="Close">&times;</button>

            <!-- Banner Image - Clickable -->
            <a href="https://tangramelectronics.com/shop" class="banner-link" target="_blank">
                <img src="https://tangramelectronics.com/wp-content/uploads/2026/02/Harmoney-Series-Poster-2-scaled.jpg" 
                     alt="Special Offer" 
                     class="banner-image">
            </a>

            <!-- Don't Show Again - Overlay on Image -->
            <!-- <div class="dont-show-container">
                <div class="dont-show">
                    <input type="checkbox" id="dontShowAgain">
                    <label for="dontShowAgain">আর দেখাবেন না</label>
                </div>
            </div> -->
        </div>
    </div>

    <script>
        // Popup Elements
        const popupOverlay = document.getElementById('popupOverlay');
        const closeBtn = document.getElementById('closeBtn');
        const dontShowAgain = document.getElementById('dontShowAgain');

        // Show popup on page load (1 second delay)
        window.addEventListener('load', function() {
            // Check if user chose "don't show again"
            if (!localStorage.getItem('tangramPopupClosed')) {
                setTimeout(function() {
                    popupOverlay.classList.add('active');
                }, 1000); // 1 second delay
            }
        });

        // Close popup function
        function closePopup() {
            popupOverlay.classList.remove('active');
            
            // If "don't show again" is checked, save to localStorage
            if (dontShowAgain && dontShowAgain.checked) {
                localStorage.setItem('tangramPopupClosed', 'true');
            }
        }

        // Close button click
        closeBtn.addEventListener('click', closePopup);

        // Close on overlay click (clicking outside popup)
        popupOverlay.addEventListener('click', function(e) {
            if (e.target === popupOverlay) {
                closePopup();
            }
        });

        // Close on ESC key press
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && popupOverlay.classList.contains('active')) {
                closePopup();
            }
        });

        // Prevent checkbox click from closing popup (if checkbox is enabled)
        const dontShowContainer = document.querySelector('.dont-show-container');
        if (dontShowContainer) {
            dontShowContainer.addEventListener('click', function(e) {
                e.stopPropagation();
            });
        }
    </script>

</body>
</html>
