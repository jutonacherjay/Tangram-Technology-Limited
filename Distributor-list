<style>
body {
    margin: 0;
    padding: 40px 16px;
    font-family: Arial, sans-serif;
    background: #f5f7fa;
}

.cards-wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    max-width: 1300px;
    margin: auto;
}

.flip-card {
    background: transparent;
    width: 100%;
    height: 420px;
    perspective: 1200px;
    transition: transform 0.3s ease;
}

.flip-card:hover {
    transform: translateY(-10px);
}

.flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.8s ease;
    transform-style: preserve-3d;
}

.flip-card.flipped .flip-card-inner {
    transform: rotateY(180deg);
}

.flip-card-front,
.flip-card-back {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    border-radius: 18px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.12);
    padding: 24px;
}

.flip-card-front {
    background: #ffffff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.flip-card-back {
    background: linear-gradient(135deg, #006747, #004d35);
    color: #ffffff;
    transform: rotateY(180deg);
    overflow-y: auto;
}

.district-icon {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: linear-gradient(135deg, #006747, #004d35);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
    color: #fff;
    margin-bottom: 20px;
    transition: transform 0.6s ease;
}

.flip-card:hover .district-icon {
    transform: rotate(360deg);
}

.division-name {
    font-size: 26px;
    font-weight: bold;
    margin-bottom: 6px;
}

.division-sub {
    color: #666;
    margin-bottom: 10px;
}

.badge {
    background: #f4a20c;
    padding: 6px 16px;
    border-radius: 20px;
    font-weight: bold;
    font-size: 14px;
}

.back-title {
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 15px;
    color: #f4a20c;
    text-align: center;
}

.distributor-item {
    background: rgba(255,255,255,0.1);
    padding: 12px;
    border-radius: 12px;
    margin-bottom: 10px;
    font-size: 14px;
    line-height: 1.5;
}

.flip-btn {
    margin-top: 15px;
    background: #006747;
    color: #fff;
    border: none;
    padding: 8px 18px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 14px;
}

.flip-btn.back {
    background: #f4a20c;
    color: #000;
}

@media (max-width: 768px) {
    .flip-card {
        height: 380px;
    }
}
</style>
