        { badge:"INDUSTRIAL GRADE", title:"22 KW <span class='tgr-accent'>Permanent Screw</span>",    desc:"Industrial-grade permanent screw air compressor engineered for high efficiency and continuous operation. Designed to deliver stable airflow and reliable performance in demanding environments.",                                                                                      features:[{icon:"⚡",text:"22 KW Power"},{icon:"💨",text:"3.2 m³/min"},{icon:"🏭",text:"Industrial Grade"},{icon:"📦",text:"300 KG Weight"}],    specs:[{label:"Model",value:"30PM"},{label:"Air Volume",value:"3.2 m³/min"},{label:"Pressure",value:"1.0 MPa"},{label:"Size",value:"1080×880×1150 mm"}],  image:"https://tangramelectronics.com/wp-content/uploads/2025/01/22kw-screw-air-compressor-Tangram-Electronics.jpg",           cta:"Request Quote", link:"https://tangramelectronics.com/product/screw-air-compressor-22kw-ip-55/" },
        { badge:"INDUSTRIAL GRADE", title:"37 KW <span class='tgr-accent'>Permanent Screw</span>",    desc:"Heavy-duty permanent screw air compressor engineered for high-capacity industrial applications. Delivers consistent airflow, energy efficiency, and reliable performance under continuous operation.",                                                                                features:[{icon:"⚡",text:"37 KW Power"},{icon:"💨",text:"5.2 m³/min"},{icon:"🔧",text:"1.0 MPa Pressure"},{icon:"📦",text:"550 KG Weight"}],    specs:[{label:"Model",value:"50PM"},{label:"Air Volume",value:"5.2 m³/min"},{label:"Pressure",value:"1.0 MPa"},{label:"Speed",value:"3000 r/min"}],           image:"https://tangramelectronics.com/wp-content/uploads/2025/01/37-KW-screw-Air-Compressor-Tangram-Electronics.jpg",          cta:"Request Quote", link:"https://tangramelectronics.com/product/37kw-screw-air-compressor/" },
        { badge:"POWER PACKED",  title:"45 KW <span class='tgr-accent'>VFD Permanent Screw</span>",   desc:"Advanced variable frequency permanent screw air compressor designed for heavy industrial operations. Equipped with inverter technology for energy efficiency, stable airflow, and reliable 24/7 performance.",                                                                        features:[{icon:"⚡",text:"45 KW Power"},{icon:"💨",text:"6.2 m³/min"},{icon:"🏭",text:"Heavy Duty"},{icon:"⏱",text:"24/7 Operation"}],          specs:[{label:"Model",value:"60PM"},{label:"Air Volume",value:"6.2 m³/min"},{label:"Pressure",value:"1.0 MPa"},{label:"Size",value:"1400×780×1210 mm"}],   image:"https://tangramelectronics.com/wp-content/uploads/2025/05/45kw-Screw-Air-compressor-Tangram-Electronics.jpg",           cta:"Learn More",    link:"https://tangramelectronics.com/product/air-compressor-price-in-bangladesh/" },
        { badge:"HIGH CAPACITY", title:"55 KW <span class='tgr-accent'>VFD Permanent Magnet</span>",  desc:"Advanced variable frequency permanent magnet screw air compressor for complex industrial operations. Ensures high efficiency, stable air output, and reduced energy consumption with low maintenance requirements.",                                                                  features:[{icon:"⚡",text:"55 KW Power"},{icon:"💨",text:"8.5 m³/min"},{icon:"🔧",text:"1.0 MPa Pressure"},{icon:"🌍",text:"Energy Efficient"}],  specs:[{label:"Model",value:"75PM"},{label:"Air Volume",value:"8.5 m³/min"},{label:"Pressure",value:"1.0 MPa"},{label:"Speed",value:"3000 r/min"}],           image:"https://tangramelectronics.com/wp-content/uploads/2025/05/55kw-Screw-Air-Compressor-Tangram-Electronics.jpg",           cta:"Get Quote",     link:"https://tangramelectronics.com/product/55kw-screw-air-compressor-price/" },
        { badge:"ENTERPRISE",    title:"75 KW <span class='tgr-accent'>Industrial Power</span>",       desc:"Heavy-duty industrial compressor for large-scale manufacturing and processing facilities. Maximum reliability with proven track record worldwide.",                                                                                                                                  features:[{icon:"⚡",text:"75 KW Power"},{icon:"💨",text:"12.6 m³/min"},{icon:"🏢",text:"Enterprise Grade"},{icon:"🛡",text:"Premium Support"}], specs:[{label:"Model",value:"TGR-C100A"},{label:"Displacement",value:"12.6 m³/min"},{label:"Pressure",value:"1.0 MPA"},{label:"Size",value:"1850×1280×1700"}], image:"https://tangramelectronics.com/wp-content/uploads/2025/01/75kw-Screw-Air-compressor-bangladesh-Tangram-Electronics.jpg", cta:"Contact Sales", link:"https://tangramelectronics.com/product/75kw-screw-air-compressor-bangladesh/" },
        { badge:"PREMIUM CLASS", title:"90 KW <span class='tgr-accent'>Enterprise Solution</span>",    desc:"Ultimate air compression solution for enterprise-level operations. Built for continuous, demanding industrial environments with minimal maintenance requirements.",                                                                                                                    features:[{icon:"⚡",text:"90 KW Power"},{icon:"💨",text:"15.0 m³/min"},{icon:"🏢",text:"Enterprise Grade"},{icon:"🛡",text:"Premium Support"}], specs:[{label:"Model",value:"TGR-C120A"},{label:"Displacement",value:"15.0 m³/min"},{label:"Pressure",value:"1.0 MPA"},{label:"Size",value:"1780×1250×1560"}], image:"https://tangramelectronics.com/wp-content/uploads/2025/06/90kw-screw-air-compressor-Bangladesh-Tangram-Electronics.jpg", cta:"Premium Support",link:"https://tangramelectronics.com/product/90kw-screw-air-compressor-bangladesh/" }
    ];

    var currentCard = 0;
    var total = products.length;
    var isLocked = false;
    var autoTimer = null;

    /* ── BUILD CARDS ── */
    function init() {
        var wrapper = document.getElementById('tgrWrapper');
        var dotsEl  = document.getElementById('tgrDots');
        if (!wrapper) return;

        products.forEach(function(p, i) {
            var card = document.createElement('div');
            card.className = 'tgr-card';
            card.innerHTML =
                '<div class="tgr-content">' +
                    '<div class="tgr-badge">' + p.badge + '</div>' +
                    '<h2 class="tgr-title">' + p.title + '</h2>' +
                    '<p class="tgr-desc">' + p.desc + '</p>' +
                    '<div class="tgr-features">' +
                        p.features.map(function(f){
                            return '<div class="tgr-feature"><span class="tgr-ficon">'+f.icon+'</span><span class="tgr-ftext">'+f.text+'</span></div>';
                        }).join('') +
                    '</div>' +
                    '<div class="tgr-specs">' +
                        p.specs.map(function(s){
                            return '<div class="tgr-spec"><span class="tgr-slabel">'+s.label+'</span><span class="tgr-sval">'+s.value+'</span></div>';
                        }).join('') +
                    '</div>' +
                    '<a class="tgr-btn" href="'+p.link+'" target="_blank" rel="noopener">'+p.cta+
                        ' <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>'+
                    '</a>' +
                '</div>' +
                '<div class="tgr-imgwrap"><div class="tgr-imgbox"><img src="'+p.image+'" alt="'+p.badge+'" class="tgr-img" loading="lazy"></div></div>';
            wrapper.appendChild(card);

            /* dot */
            var dot = document.createElement('div');
            dot.className = 'tgr-dot';
            (function(idx){ dot.addEventListener('click', function(){ stopAuto(); goTo(idx); startAuto(); }); })(i);
            dotsEl.appendChild(dot);
        });

        goTo(0);
        startAuto();
        setupSwipe();
        setWrapperHeight();
        window.addEventListener('resize', setWrapperHeight);
    }

    /* ── DYNAMIC WRAPPER HEIGHT (mobile only) ── */
    function setWrapperHeight() {
        if (window.innerWidth > 600) return;
        var wrapper = document.getElementById('tgrWrapper');
        if (!wrapper) return;
        var cards = wrapper.querySelectorAll('.tgr-card');
        var maxH = 0;
        cards.forEach(function(card) {
            /* measure each card at natural size */
            var prev = {
                position: card.style.position,
                transform: card.style.transform,
                top: card.style.top,
                left: card.style.left,
                opacity: card.style.opacity,
                display: card.style.display
            };
            card.style.position = 'relative';
            card.style.transform = 'none';
            card.style.top = 'auto';
            card.style.left = 'auto';
            card.style.opacity = '0';
            card.style.display = 'grid';
            var h = card.offsetHeight;
            if (h > maxH) maxH = h;
            card.style.position = prev.position;
            card.style.transform = prev.transform;
            card.style.top = prev.top;
            card.style.left = prev.left;
            card.style.opacity = prev.opacity;
            card.style.display = prev.display;
        });
        if (maxH > 0) wrapper.style.height = (maxH + 24) + 'px';
    }

    /* ── SET WRAPPER HEIGHT TO ACTIVE CARD HEIGHT (mobile only) ── */
    function setWrapperHeight() {
        if (window.innerWidth > 600) return;
        var wrapper = document.getElementById('tgrWrapper');
        var active = wrapper.querySelector('.tgr-active-center');
        if (!active) return;
        /* temporarily make visible to measure */
        active.style.visibility = 'hidden';
        active.style.transform = 'translateX(-50%) translateY(0) scale(1)';
        active.style.top = '0';
        var h = active.offsetHeight;
        active.style.visibility = '';
        active.style.transform = '';
        active.style.top = '';
        wrapper.style.height = (h + 20) + 'px';
    }

    /* ── POSITION CARDS ── */
    function goTo(index) {
        var cards = document.querySelectorAll('.tgr-card');
        var dots  = document.querySelectorAll('.tgr-dot');

        cards.forEach(function(c, i) {
            c.classList.remove('tgr-active-center','tgr-side-left','tgr-side-right','tgr-far-left','tgr-far-right');
            var d = i - index;
            if      (d === 0)  c.classList.add('tgr-active-center');
            else if (d === -1) c.classList.add('tgr-side-left');
            else if (d === 1)  c.classList.add('tgr-side-right');
            else if (d < -1)   c.classList.add('tgr-far-left');
            else               c.classList.add('tgr-far-right');
        });

        dots.forEach(function(d, i) {
            d.classList.toggle('tgr-dot-active', i === index);
        });

        currentCard = index;
    }

    /* ── AUTO SLIDE ── */
    function startAuto() {
        stopAuto();
        autoTimer = setInterval(function() {
            goTo(currentCard < total - 1 ? currentCard + 1 : 0);
        }, 3000);
    }

    function stopAuto() {
        if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
    }

    /* ── NEXT / PREV ── */
    function next() {
        if (isLocked) return;
        isLocked = true;
        goTo(currentCard < total - 1 ? currentCard + 1 : 0);
        setTimeout(function(){ isLocked = false; }, 650);
    }

    function prev() {
        if (isLocked) return;
        isLocked = true;
        goTo(currentCard > 0 ? currentCard - 1 : total - 1);
        setTimeout(function(){ isLocked = false; }, 650);
    }

    /* ── LEFT/RIGHT SWIPE ONLY ── */
    function setupSwipe() {
        var el = document.getElementById('tgrWrapper');
        var sx = 0, sy = 0;

        el.addEventListener('touchstart', function(e) {
            sx = e.touches[0].clientX;
            sy = e.touches[0].clientY;
        }, { passive: true });

        el.addEventListener('touchend', function(e) {
            var dx = sx - e.changedTouches[0].clientX;
            var dy = sy - e.changedTouches[0].clientY;
            if (Math.abs(dx) < 40 || Math.abs(dx) < Math.abs(dy)) return;
            stopAuto();
            if (dx > 0) next(); else prev();
            startAuto();
        }, { passive: true });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

})();
</script>

</body>
</html>
