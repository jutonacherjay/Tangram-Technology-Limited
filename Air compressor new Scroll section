<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tangram Air Compressor</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        .tgr-section {
            position: relative;
            width: 100%;
            height: 100vh;
            background: #ffffff;
        }

        .tgr-heading {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 20;
            background: #ffffff;
        }

        .tgr-heading h2 {
            font-family: 'Poppins', sans-serif;
            font-size: 1.3em;
            font-weight: 800;
            color: #0d1f3c;
            margin: 0;
        }

        .tgr-heading h2 span { color: #00b8b8; }

        .tgr-inner {
            position: absolute;
            top: 48px; left: 0; right: 0; bottom: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #ffffff;
            clip-path: inset(0 0 0 0);
            overflow: hidden;
        }

        .tgr-wrapper {
            position: relative;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        /* ── CARD BASE ── */
        .tgr-card {
            position: absolute;
            width: 68%;
            max-width: 1000px;
            background: linear-gradient(135deg, #0b1a35 0%, #091428 60%, #070f1e 100%);
            border: 1px solid rgba(0,210,210,0.2);
            border-radius: 20px;
            padding: 40px 48px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 48px;
            align-items: center;
            top: 50%; left: 50%;
            transform: translateX(calc(-50% + 160%)) translateY(-50%) scale(0.72);
            opacity: 0;
            pointer-events: none;
            will-change: transform, opacity, filter;
            box-shadow: 0 30px 80px rgba(0,0,0,0.18);
            transition:
                transform 0.65s cubic-bezier(0.22,1,0.36,1),
                opacity   0.5s cubic-bezier(0.22,1,0.36,1),
                filter    0.5s ease,
                box-shadow 0.5s ease;
            filter: blur(2px);
        }

        .tgr-card::before {
            content: '';
            position: absolute;
            top: -80px; right: -80px;
            width: 350px; height: 350px;
            background: radial-gradient(circle, rgba(0,200,200,0.06) 0%, transparent 60%);
            border-radius: 50%;
            pointer-events: none;
        }

        .tgr-card { z-index: 1; }

        .tgr-card.tgr-active-center {
            transform: translateX(-50%) translateY(-50%) scale(1);
            opacity: 1;
            pointer-events: auto;
            filter: blur(0px);
            box-shadow: 0 30px 80px rgba(0,0,0,0.35);
            z-index: 10;
        }

        .tgr-card.tgr-side-left {
            transform: translateX(calc(-50% - 52%)) translateY(-50%) scale(0.72);
            opacity: 0.45;
            pointer-events: none;
            filter: blur(1.5px);
            box-shadow: 0 10px 40px rgba(0,0,0,0.12);
            z-index: 5;
        }

        .tgr-card.tgr-side-right {
            transform: translateX(calc(-50% + 52%)) translateY(-50%) scale(0.72);
            opacity: 0.45;
            pointer-events: none;
            filter: blur(1.5px);
            box-shadow: 0 10px 40px rgba(0,0,0,0.12);
            z-index: 5;
        }

        .tgr-card.tgr-far-left {
            transform: translateX(calc(-50% - 110%)) translateY(-50%) scale(0.6);
            opacity: 0;
            pointer-events: none;
            filter: blur(3px);
            z-index: 1;
        }

        .tgr-card.tgr-far-right {
            transform: translateX(calc(-50% + 110%)) translateY(-50%) scale(0.6);
            opacity: 0;
            pointer-events: none;
            filter: blur(3px);
            z-index: 1;
        }

        /* ── DOTS ── */
        .tgr-dots {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 8px;
            z-index: 20;
        }

        .tgr-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: rgba(0,210,210,0.25);
            border: 1px solid rgba(0,210,210,0.4);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .tgr-dot.tgr-dot-active {
            background: #00d4d4;
            transform: scale(1.3);
        }

        /* ── CARD CONTENT ── */
        .tgr-content {
            position: relative; z-index: 2;
            display: flex; flex-direction: column; gap: 16px;
        }

        .tgr-badge {
            display: inline-block; width: fit-content;
            padding: 5px 16px;
            background: rgba(0,210,210,0.08);
            border: 1px solid rgba(0,210,210,0.4);
            border-radius: 50px;
            font-size: 0.72em; font-weight: 700; letter-spacing: 1.5px;
            color: #00d4d4; text-transform: uppercase;
            font-family: 'Poppins', sans-serif;
        }

        .tgr-title {
            font-family: 'Poppins', sans-serif;
            font-size: 2.4em; font-weight: 800;
            line-height: 1.15; color: #e8f4ff;
            letter-spacing: -0.5px; margin: 0;
        }

        .tgr-title .tgr-accent { color: #00cfff; }

        .tgr-desc {
            font-size: 0.88em; line-height: 1.7;
            color: #7a9dbf; font-family: 'Poppins', sans-serif; margin: 0;
        }

        .tgr-features { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

        .tgr-feature {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 14px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(0,210,210,0.15);
            border-left: 3px solid rgba(0,210,210,0.45);
            border-radius: 8px;
        }

        .tgr-ficon { font-size: 1.1em; width: 22px; flex-shrink: 0; text-align: center; }
        .tgr-ftext { font-size: 0.83em; font-weight: 600; color: #cce8f0; font-family: 'Poppins', sans-serif; }

        .tgr-specs {
            display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
            padding-top: 14px;
            border-top: 1px solid rgba(0,200,200,0.12);
        }

        .tgr-spec { display: flex; flex-direction: column; gap: 3px; }

        .tgr-slabel {
            font-size: 0.67em; color: #2a8fa8;
            text-transform: uppercase; letter-spacing: 1.2px;
            font-weight: 700; font-family: 'Poppins', sans-serif;
        }

        .tgr-sval {
            font-size: 0.95em; font-weight: 700;
            color: #e0f0ff; font-family: 'Poppins', sans-serif;
        }

        .tgr-btn {
            display: inline-flex; align-items: center; gap: 10px;
            width: fit-content;
            padding: 11px 26px;
            background: linear-gradient(135deg, #00c8c8 0%, #007a8a 100%);
            border: none; border-radius: 8px; color: #fff;
            font-family: 'Poppins', sans-serif; font-size: 0.83em; font-weight: 700;
            cursor: pointer;
            box-shadow: 0 8px 24px rgba(0,200,200,0.22);
            text-transform: uppercase; letter-spacing: 0.8px; margin-top: 4px;
            transition: transform 0.2s, box-shadow 0.2s;
            text-decoration: none;
        }

        .tgr-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,200,200,0.32); }
        .tgr-btn svg { width: 15px; height: 15px; }

        /* ── IMAGE ── */
        .tgr-imgwrap {
            position: relative; z-index: 2; width: 100%;
            display: flex; align-items: center; justify-content: center;
        }

        .tgr-imgbox {
            width: 100%; aspect-ratio: 4/3;
            display: flex; align-items: center; justify-content: center;
            background: radial-gradient(circle, rgba(0,180,200,0.05) 0%, transparent 65%);
            border-radius: 14px;
        }

        .tgr-img {
            width: 100%; height: 100%;
            object-fit: contain; display: block;
            filter: drop-shadow(0 10px 30px rgba(0,160,200,0.18));
        }

        /* ── RESPONSIVE 900px ── */
        @media (max-width: 900px) {
            .tgr-heading { height: 40px; }
            .tgr-heading h2 { font-size: 1.05em; }
            .tgr-inner { top: 40px; }
            .tgr-card { width: 70%; padding: 22px 18px; gap: 14px; }
            .tgr-title { font-size: 1.4em; }
            .tgr-desc { font-size: 0.8em; }
        }

        /* ── MOBILE 600px — desktop animation, card-height section ── */
        @media (max-width: 600px) {

            /* Section shrinks to fit content */
            .tgr-section {
                height: auto;
                min-height: auto;
            }

            /* Heading: stays on top, normal flow */
            .tgr-heading {
                position: relative;
                top: auto; left: auto; right: auto;
                height: 36px;
                background: #ffffff;
            }
            .tgr-heading h2 { font-size: 0.9em; }

            /* Inner: flex column — overflow-x hidden clips side cards, overflow-y visible keeps full card */
            .tgr-inner {
                position: relative;
                top: auto; left: auto; right: auto; bottom: auto;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: flex-start;
                height: auto;
                overflow-x: hidden;
                overflow-y: visible;
                clip-path: none;
                background: #ffffff;
                padding: 8px 0 0;
            }

            /* Carousel stage — height must fit the tallest card */
            .tgr-wrapper {
                position: relative;
                width: 100%;
                height: 300px;
                flex-shrink: 0;
                overflow: visible;
                z-index: 1;
            }

            /* Cards keep absolute + transition for animation */
            .tgr-card {
                position: absolute;
                width: 76%;
                max-width: none;
                padding: 14px 12px;
                border-radius: 12px;
                gap: 8px;
                grid-template-columns: 1fr 1fr;
                grid-template-areas: "content img";
                align-items: center;
                top: 50%; left: 50%;
                will-change: transform, opacity, filter;
                transition:
                    transform 0.65s cubic-bezier(0.22,1,0.36,1),
                    opacity   0.5s cubic-bezier(0.22,1,0.36,1),
                    filter    0.5s ease,
                    box-shadow 0.5s ease;
            }

            /* Mobile carousel states — same logic, tighter offsets */
            .tgr-card.tgr-active-center {
                transform: translateX(-50%) translateY(-50%) scale(1);
                opacity: 1;
                pointer-events: auto;
                filter: blur(0px);
                box-shadow: 0 20px 50px rgba(0,0,0,0.4);
                z-index: 10;
            }

            .tgr-card.tgr-side-left {
                transform: translateX(calc(-50% - 50%)) translateY(-50%) scale(0.72);
                opacity: 0.4;
                pointer-events: none;
                filter: blur(1.5px);
                box-shadow: 0 8px 30px rgba(0,0,0,0.12);
                z-index: 5;
            }

            .tgr-card.tgr-side-right {
                transform: translateX(calc(-50% + 50%)) translateY(-50%) scale(0.72);
                opacity: 0.4;
                pointer-events: none;
                filter: blur(1.5px);
                box-shadow: 0 8px 30px rgba(0,0,0,0.12);
                z-index: 5;
            }

            .tgr-card.tgr-far-left {
                transform: translateX(calc(-50% - 105%)) translateY(-50%) scale(0.6);
                opacity: 0;
                pointer-events: none;
                filter: blur(3px);
                z-index: 1;
            }

            .tgr-card.tgr-far-right {
                transform: translateX(calc(-50% + 105%)) translateY(-50%) scale(0.6);
                opacity: 0;
                pointer-events: none;
                filter: blur(3px);
                z-index: 1;
            }

            /* Dots: natural flow, sits directly below wrapper */
            .tgr-dots {
                position: relative;
                bottom: auto;
                left: auto;
                transform: none;
                justify-content: center;
                padding: 10px 0 12px;
                z-index: 20;
            }

            .tgr-content { grid-area: content; gap: 6px; }
            .tgr-imgwrap { grid-area: img; }

            .tgr-badge { font-size: 0.6em; padding: 3px 10px; }
            .tgr-title { font-size: 0.9em; line-height: 1.2; }
            .tgr-desc { display: none; }

            .tgr-features { grid-template-columns: 1fr; gap: 4px; }
            .tgr-feature { padding: 5px 7px; border-radius: 5px; gap: 6px; }
            .tgr-ficon { font-size: 0.85em; width: 16px; }
            .tgr-ftext { font-size: 0.68em; }

            .tgr-specs { display: none; }

            .tgr-btn {
                padding: 7px 12px;
                font-size: 0.68em;
                letter-spacing: 0.4px;
                margin-top: 2px;
                width: 100%;
                justify-content: center;
            }

            .tgr-imgbox {
                aspect-ratio: 1/1;
                border-radius: 10px;
            }
        }

        @media (max-width: 400px) {
            .tgr-wrapper { height: 200px; }
            .tgr-card { width: 80%; padding: 10px; gap: 6px; }
            .tgr-title { font-size: 0.8em; }
            .tgr-features { gap: 3px; }
            .tgr-ftext { font-size: 0.62em; }
        }
    </style>
</head>
<body>

