  .tng-title { font-size: 1.7rem; }
  .tng-divider { height: 30px; margin-bottom: 28px; }
  .tng-outer { padding: 0 34px; }
  .tng-slide { flex: 0 0 50%; max-width: 50%; padding: 0 8px; }
