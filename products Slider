<style>
.tng-section { padding: 60px 20px; text-align: center; background: #fff; }
.tng-title { font-size: 2.4rem; font-weight: 400; color: #077d68; margin-bottom: 10px; letter-spacing: 1px; }
.tng-divider { width: 3px; height: 40px; background: #077d68; margin: 0 auto 50px; }
.tng-outer { position: relative; max-width: 1100px; margin: 0 auto; padding: 0 48px; box-sizing: border-box; }
.tng-viewport { overflow: hidden; width: 100%; }
.tng-track { display: flex; transition: transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94); will-change: transform; }
.tng-slide { flex: 0 0 33.333%; max-width: 33.333%; padding: 0 12px; display: flex; flex-direction: column; align-items: center; opacity: 0.25; transition: opacity 0.5s ease; box-sizing: border-box; }
.tng-slide.active { opacity: 1; }
.tng-img-wrap { width: 100%; height: 260px; display: flex; align-items: center; justify-content: center; }
.tng-slide img { width: 100%; height: 260px; object-fit: contain; transform: scale(0.6); opacity: 0; transition: transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.5s ease; display: block; }
.tng-slide.active img { transform: scale(1); opacity: 1; }
.tng-pname { font-size: 15px; font-weight: 600; color: #077d68; margin-top: 14px; text-align: center; opacity: 0; transform: translateY(8px); transition: opacity 0.4s ease 0.2s, transform 0.4s ease 0.2s; }
.tng-slide.active .tng-pname { opacity: 1; transform: translateY(0); }
.tng-btn { display: inline-flex; align-items: center; gap: 10px; margin-top: 12px; color: #077d68; font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-decoration: none; opacity: 0; transform: translateY(10px); transition: opacity 0.4s ease 0.35s, transform 0.4s ease 0.35s; }
.tng-slide.active .tng-btn { opacity: 1; transform: translateY(0); }
.tng-btn .tng-circle { width: 30px; height: 30px; border-radius: 50%; border: 1.5px solid #077d68; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
.tng-btn .tng-arrow { font-size: 13px; color: #077d68; transition: color 0.2s; line-height: 1; }
.tng-btn:hover .tng-circle { background: #077d68; }
.tng-btn:hover .tng-arrow { color: #fff; }
.tng-nav { position: absolute; top: 38%; transform: translateY(-50%); background: none; border: none; font-size: 2.8rem; color: #077d68; cursor: pointer; padding: 8px 10px; z-index: 10; font-weight: 300; line-height: 1; transition: color 0.2s; }
.tng-nav:hover { color: #055a4a; }
.tng-prev { left: -4px; }
.tng-next { right: -4px; }
.tng-dots { display: flex; justify-content: center; flex-wrap: wrap; gap: 8px; margin-top: 36px; }
.tng-dot { width: 9px; height: 9px; border-radius: 50%; background: #ccc; border: none; cursor: pointer; padding: 0; transition: background 0.3s, transform 0.2s; }
.tng-dot.active { background: #077d68; transform: scale(1.4); }

@media (max-width: 640px) {
