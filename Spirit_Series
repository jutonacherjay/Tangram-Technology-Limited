<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Spirit Series</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;900&family=Work+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --light-mint: #e8f8f5;
            --soft-mint: #c8f2ec;
            --mint: #b2ece3;
            --primary: #2ecfb0;
            --primary-dark: #0a9e84;
            --primary-darker: #077d68;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Work Sans', sans-serif; background: white; color: #1a1a1a; }
        .page-header { text-align: center; padding: 4rem 5% 3rem; background: linear-gradient(135deg, var(--light-mint) 0%, white 100%); }
        .page-title { font-family: 'Playfair Display', serif; font-size: 3rem; font-weight: 900; color: var(--primary-darker); margin: 0 0 0.5rem 0; }
        .page-subtitle { color: var(--primary-dark); font-size: 1.1rem; }
        .container { max-width: 1400px; margin: 0 auto; padding: 4rem 5%; }
        .category-section { margin-bottom: 5rem; }
        .category-title { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--primary-dark); margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 3px solid var(--mint); display: inline-block; }
        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem; }
        .product-card { background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); cursor: pointer; opacity: 0; transform: translateY(50px); border: 2px solid transparent; }
        .product-card.animate { animation: slideUp 0.6s ease forwards; }
        @keyframes slideUp { to { opacity: 1; transform: translateY(0); } }
        .product-card:hover { transform: translateY(-8px); box-shadow: 0 12px 40px rgba(46, 207, 176, 0.2); border-color: var(--primary); }
        .product-image { width: 100%; height: 220px; object-fit: cover; background: var(--light-mint); }
        .product-info { padding: 1.5rem; }
        .product-name { font-weight: 600; font-size: 1.1rem; color: var(--primary-darker); margin-bottom: 0.5rem; }
        .product-description { color: #666; font-size: 0.9rem; line-height: 1.4; }
        .view-details { display: inline-block; margin-top: 1rem; color: var(--primary); font-weight: 500; font-size: 0.9rem; transition: all 0.3s ease; }
        .product-card:hover .view-details { transform: translateX(5px); }
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.8); z-index: 1000; overflow-y: auto; padding: 2rem; }
        .modal.active { display: flex; align-items: center; justify-content: center; }
        .modal-content { background: white; border-radius: 24px; max-width: 900px; width: 100%; max-height: 90vh; overflow-y: auto; position: relative; animation: slideIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes slideIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .modal-close { position: absolute; top: 1.5rem; right: 1.5rem; width: 40px; height: 40px; background: var(--primary); border: none; border-radius: 50%; color: white; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; z-index: 10; }
        .modal-close:hover { background: var(--primary-dark); transform: rotate(90deg); }
        .modal-image { width: 100%; height: 400px; object-fit: cover; background: var(--light-mint); }
        .modal-info { padding: 2.5rem; }
        .modal-title { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--primary-darker); margin-bottom: 1rem; }
        .modal-description { color: #666; line-height: 1.6; margin-bottom: 2rem; }
        .specifications { background: var(--light-mint); border-radius: 12px; padding: 1.5rem; }
        .spec-title { font-weight: 600; color: var(--primary-darker); margin-bottom: 1rem; font-size: 1.2rem; }
        .spec-item { display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--mint); }
        .spec-item:last-child { border-bottom: none; }
        .spec-label { font-weight: 500; color: var(--primary-dark); }
        .spec-value { color: #555; }
        @media (max-width: 768px) {
            .page-title { font-size: 2rem; }
            .page-subtitle { font-size: 1rem; }
            .container { padding: 2rem 5%; }
            .products-grid { grid-template-columns: 1fr; gap: 1.5rem; }
            .modal-content { margin: 1rem; }
            .modal-image { height: 250px; }
            .modal-info { padding: 1.5rem; }
            .modal-title { font-size: 1.5rem; }
        }
    </style>
</head>
<body>
    <div class="page-header">
        <h1 class="page-title">Spirit Series </h1>
        <p class="page-subtitle">Premium electrical solutions for modern living</p>
    </div>
    <div class="container" id="productsContainer"></div>
    <div class="modal" id="productModal">
        <div class="modal-content">
            <button class="modal-close" onclick="closeModal()">×</button>
            <img class="modal-image" id="modalImage" alt="">
            <div class="modal-info">
                <h2 class="modal-title" id="modalTitle"></h2>
                <p class="modal-description" id="modalDescription"></p>
                <div class="specifications">
                    <h3 class="spec-title">Specifications</h3>
                    <div id="modalSpecs"></div>
                </div>
            </div>
        </div>
    </div>
    <script>
        const productsData={categories:[{id:1,name:'Spirit Series',subcategories:[{id:101,name:'Holder',products:[{id:1001,name:'Round Batten Holder',description:'High-quality batten holder',image:'https://tangramelectronics.com/wp-content/uploads/2025/06/Tangram-Round-Batten-Holder.jpg',specifications:{'Material':'V0 PC Plastic','Type':'Round','Warranty':'1 Years'}},{id:1002,name:'Big Octagonal Holder',description:'Premium octagonal holder',image:'https://tangramelectronics.com/wp-content/uploads/2025/01/Image_20260106110218.jpg',specifications:{'Material':'V0 PC Plastic','Type':'Octagonal','Warranty':'1 Years'}},{id:1003,name:'Batten Holder B/C',description:'Standard batten holder',image:'https://tangramelectronics.com/wp-content/uploads/2025/06/Tangram-Batten-Holder-b-c.jpg',specifications:{'Material':'V0 PC Plastic','Type':'B/C','Warranty':'1 Years'}},{id:1004,name:'Square Holder',description:'Modern square design',image:'https://tangramelectronics.com/wp-content/uploads/2025/06/Tangram-Spirit-Square-Holder.jpg',specifications:{'Material':'V0 PC Plastic','Shape':'Square','Warranty':'1 Years'}},{id:1005,name:'pendant Holder C',description:'Modern square design',image:'https://tangramelectronics.com/wp-content/uploads/2025/12/Pendant-Holder-C.jpg',specifications:{'Material':'Plastic','Shape':'Square','Warranty':'1 Years'}},{id:1006,name:'pendant Holder A/B',description:'Modern square design',image:'https://tangramelectronics.com/wp-content/uploads/2025/12/Pendant-Holder-AB.jpg',specifications:{'Material':'V0 PC Plastic','Shape':'Square','Warranty':'1 Years'}},{id:1007,name:'Heat Resistant Holder',description:'Temperature resistant holder',image:'https://tangramelectronics.com/wp-content/uploads/2026/02/Image_20260224144453.jpg',specifications:{'Material':'Heat Resistant Plastic','Rating':'High','Warranty':'1 Years'}}]},{id:102,name:'Ceiling Rose',products:[{id:1008,name:'Small Ceiling Rose',description:'Compact ceiling rose',image:'https://tangramelectronics.com/wp-content/uploads/2025/01/Tangram-Small-Ceiling-Rose.jpg',specifications:{'Size':'Small','Material':'V0 PC Plastic','Warranty':'1 Years'}},{id:1009,name:'Big Ceiling Rose',description:'Large ceiling rose',image:'https://tangramelectronics.com/wp-content/uploads/2025/01/Tangram-Big-ceiling-rose.jpg',specifications:{'Size':'Big','Material':'Plastic','Warranty':'1 Years'}},{id:1010,name:'Square Ceiling Rose',description:'Square design rose',image:'https://tangramelectronics.com/wp-content/uploads/2025/12/Image_20251230114103.jpg',specifications:{'Shape':'Square','Material':'Plastic','Warranty':'1 Years'}}]},{id:103,name:'Switch & Sockets',products:[{id:1011,name:'Fuse',description:'Safety protection device',image:'https://tangramelectronics.com/wp-content/uploads/2025/12/Image_20251228104005.jpg',specifications:{'Type':'Rewirable/Plug','Material':'V0 PC Plastic','Conductor':'Copper conductor'}},{id:1012,name:'Indicator',description:'LED status indicator',image:'https://tangramelectronics.com/wp-content/uploads/2025/04/Tangram-Spirit-Piano-Indicator-Switch.jpg',specifications:{'Type':'LED','Color':'Red','Voltage':'230V AC'}},{id:1013,name:'2pin Socket',description:'Standard 2-pin outlet',image:'https://tangramelectronics.com/wp-content/uploads/2025/06/Tangram-Piano-2-Pin-socket.jpg',specifications:{'Pins':'2','Material':'Fire-retardant polycarbonate body','Voltage':'250V AC'}},{id:1014,name:'Regulator',description:'Power regulation unit',image:'https://tangramelectronics.com/wp-content/uploads/2025/04/Spirit-Smart-Fan-Regulator.jpg',specifications:{'Type':'Fan/Speed','Material':'Polycarbonate Virgin Resin','Speed Levels':'Smooth fan speed control'}},{id:1015,name:'2 way switch',description:'Tangram Spirit Piano 2-Way Switch – Premium Electrical Switch',image:'https://tangramelectronics.com/wp-content/uploads/2025/12/2way-Switch.jpg',specifications:{'Type':'Fire-proof V0 PC / Plastic','Conductor':'Copper ','Warranty':'1 year'}},{id:1016,name:'Bell Push',description:'Doorbell push button',image:'https://tangramelectronics.com/wp-content/uploads/2025/04/Tangram-Spirit-Bell-Push-switch.jpg',specifications:{'Type':'Fire-proof V0 PC / Plastic','Conductor':'Copper ','Warranty':'1 year'}}]}]}]};function renderProducts(){const container=document.getElementById('productsContainer');const spiritSeries=productsData.categories[0];spiritSeries.subcategories.forEach(subcategory=>{const section=document.createElement('div');section.className='category-section';section.innerHTML=`<h2 class="category-title">${subcategory.name}</h2><div class="products-grid"></div>`;const grid=section.querySelector('.products-grid');subcategory.products.forEach((product,index)=>{const card=document.createElement('div');card.className='product-card';card.style.animationDelay=`${index*0.1}s`;card.innerHTML=`<img src="${product.image}" alt="${product.name}" class="product-image"><div class="product-info"><h3 class="product-name">${product.name}</h3><p class="product-description">${product.description}</p><span class="view-details">View Details →</span></div>`;card.onclick=()=>openModal(product);grid.appendChild(card);});container.appendChild(section);});observeCards();}function observeCards(){const observer=new IntersectionObserver((entries)=>{entries.forEach(entry=>{if(entry.isIntersecting){entry.target.classList.add('animate');}});},{threshold:0.1});document.querySelectorAll('.product-card').forEach(card=>{observer.observe(card);});}function openModal(product){const modal=document.getElementById('productModal');document.getElementById('modalImage').src=product.image;document.getElementById('modalTitle').textContent=product.name;document.getElementById('modalDescription').textContent=product.description;const specsContainer=document.getElementById('modalSpecs');specsContainer.innerHTML='';Object.entries(product.specifications).forEach(([key,value])=>{specsContainer.innerHTML+=`<div class="spec-item"><span class="spec-label">${key}</span><span class="spec-value">${value}</span></div>`;});modal.classList.add('active');document.body.style.overflow='hidden';}function closeModal(){const modal=document.getElementById('productModal');modal.classList.remove('active');document.body.style.overflow='auto';}document.getElementById('productModal').addEventListener('click',(e)=>{if(e.target.id==='productModal'){closeModal();}});renderProducts();
    </script>
</body>
</html>
