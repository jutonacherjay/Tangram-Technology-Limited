<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Downloads - Product Catalogs</title>
    <style>
        :root {
            --primary: #10B981;
            --primary-dark: #059669;
            --primary-light: #34D399;
            --accent: #3B82F6;
            --accent-dark: #2563EB;
            --surface: #F9FAFB;
            --card-bg: #FFFFFF;
            --text: #111827;
            --text-light: #6B7280;
            --text-lighter: #9CA3AF;
            --border: #E5E7EB;
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 10px 30px rgba(0, 0, 0, 0.12);
            --shadow-xl: 0 20px 50px rgba(0, 0, 0, 0.15);
            --gradient-1: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --gradient-2: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --gradient-3: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            --gradient-4: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
            --gradient-5: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            background: var(--surface);
            color: var(--text);
            line-height: 1.6;
            overflow-x: hidden;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Background decoration */
        .bg-decoration {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
            pointer-events: none;
        }

        .bg-shape {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.1;
            animation: float-shapes 20s ease-in-out infinite;
        }

        .bg-shape-1 {
            top: 10%;
            left: 10%;
            width: 400px;
            height: 400px;
            background: var(--gradient-1);
            animation-delay: 0s;
        }

        .bg-shape-2 {
            top: 60%;
            right: 10%;
            width: 500px;
            height: 500px;
            background: var(--gradient-3);
            animation-delay: -7s;
        }

        .bg-shape-3 {
            bottom: 10%;
            left: 40%;
            width: 350px;
            height: 350px;
            background: var(--gradient-4);
            animation-delay: -14s;
        }

        @keyframes float-shapes {
            0%, 100% {
                transform: translate(0, 0) rotate(0deg);
            }
            33% {
                transform: translate(30px, -30px) rotate(120deg);
            }
            66% {
                transform: translate(-20px, 20px) rotate(240deg);
            }
        }

        /* Header Section */
        .header-section {
            padding: 80px 0 60px;
            text-align: center;
            position: relative;
        }

        .page-title {
            font-family: Arial, Helvetica, sans-serif;
            font-size: clamp(42px, 6vw, 64px);
            font-weight: bold;
            background: linear-gradient(135deg, var(--text) 0%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 20px;
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards;
        }

        .page-subtitle {
            font-size: clamp(16px, 2vw, 18px);
            color: var(--text-light);
            max-width: 600px;
            margin: 0 auto 40px;
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards 0.2s;
        }

        .contact-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 32px;
            background: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 16px rgba(16, 185, 129, 0.3);
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards 0.4s;
        }

        .contact-btn:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(16, 185, 129, 0.4);
        }

        .contact-btn svg {
            width: 18px;
            height: 18px;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Downloads Grid */
        .downloads-section {
            padding: 40px 0 100px;
        }

        .downloads-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 32px;
            margin-top: 40px;
        }

        .download-card {
            background: var(--card-bg);
            border-radius: 24px;
            padding: 40px;
            position: relative;
            overflow: hidden;
            border: 2px solid var(--border);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 0;
            transform: translateY(40px);
        }

        .download-card.animate-in {
            animation: slideUp 0.7s ease forwards;
        }

        .download-card:nth-child(1) { animation-delay: 0.1s; }
        .download-card:nth-child(2) { animation-delay: 0.2s; }
        .download-card:nth-child(3) { animation-delay: 0.3s; }
        .download-card:nth-child(4) { animation-delay: 0.4s; }
        .download-card:nth-child(5) { animation-delay: 0.5s; }

        @keyframes slideUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .download-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--gradient-1);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.5s ease;
        }

        .download-card:nth-child(2)::before {
            background: var(--gradient-2);
        }

        .download-card:nth-child(3)::before {
            background: var(--gradient-3);
        }

        .download-card:nth-child(4)::before {
            background: var(--gradient-4);
        }

        .download-card:nth-child(5)::before {
            background: var(--gradient-5);
        }

        .download-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-xl);
            border-color: var(--primary);
        }

        .download-card:hover::before {
            transform: scaleX(1);
        }

        .pdf-icon-wrapper {
            width: 80px;
            height: 80px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            position: relative;
            transition: all 0.4s ease;
        }

        .download-card:nth-child(1) .pdf-icon-wrapper {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        }

        .download-card:nth-child(2) .pdf-icon-wrapper {
            background: linear-gradient(135deg, rgba(240, 147, 251, 0.1) 0%, rgba(245, 87, 108, 0.1) 100%);
        }

        .download-card:nth-child(3) .pdf-icon-wrapper {
            background: linear-gradient(135deg, rgba(79, 172, 254, 0.1) 0%, rgba(0, 242, 254, 0.1) 100%);
        }

        .download-card:nth-child(4) .pdf-icon-wrapper {
            background: linear-gradient(135deg, rgba(67, 233, 123, 0.1) 0%, rgba(56, 249, 215, 0.1) 100%);
        }

        .download-card:nth-child(5) .pdf-icon-wrapper {
            background: linear-gradient(135deg, rgba(250, 112, 154, 0.1) 0%, rgba(254, 225, 64, 0.1) 100%);
        }

        .download-card:hover .pdf-icon-wrapper {
            transform: scale(1.1) rotate(-5deg);
        }

        .pdf-icon-wrapper svg {
            width: 40px;
            height: 40px;
            transition: transform 0.3s ease;
        }

        .download-card:hover .pdf-icon-wrapper svg {
            transform: scale(1.15);
        }

        .card-title {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 22px;
            font-weight: bold;
            color: var(--text);
            margin-bottom: 8px;
            text-align: center;
            line-height: 1.3;
        }

        .card-description {
            font-size: 14px;
            color: var(--text-light);
            text-align: center;
            margin-bottom: 24px;
        }

        .download-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 14px 24px;
            background: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .download-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }

        .download-btn:hover::before {
            left: 100%;
        }

        .download-btn:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
        }

        .download-btn svg {
            width: 20px;
            height: 20px;
            transition: transform 0.3s ease;
        }

        .download-btn:hover svg {
            transform: translateY(2px);
        }

        /* File size badge */
        .file-size {
            position: absolute;
            top: 16px;
            right: 16px;
            padding: 6px 12px;
            background: rgba(0, 0, 0, 0.05);
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-light);
        }

        /* Info Section */
        .info-section {
            padding: 80px 0;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            position: relative;
            overflow: hidden;
        }

        .info-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="100" height="100" patternUnits="userSpaceOnUse"><path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(%23grid)"/></svg>');
        }

        .info-content {
            position: relative;
            text-align: center;
            max-width: 700px;
            margin: 0 auto;
            color: white;
        }

        .info-title {
            font-family: Arial, Helvetica, sans-serif;
            font-size: clamp(28px, 4vw, 40px);
            font-weight: bold;
            margin-bottom: 16px;
        }

        .info-text {
            font-size: 18px;
            opacity: 0.9;
            margin-bottom: 32px;
        }

        .info-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 32px;
            background: white;
            color: var(--primary);
            text-decoration: none;
            border-radius: 50px;
            font-weight: bold;
            font-size: 16px;
            transition: all 0.3s ease;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        }

        .info-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
        }

        .info-btn svg {
            width: 20px;
            height: 20px;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .downloads-grid {
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 24px;
            }
        }

        @media (max-width: 768px) {
            .header-section {
                padding: 60px 0 40px;
            }

            .downloads-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .download-card {
                padding: 32px 24px;
            }

            .info-section {
                padding: 60px 0;
            }

            .container {
                padding: 0 16px;
            }
        }

        @media (max-width: 480px) {
            .download-card {
                padding: 28px 20px;
            }

            .pdf-icon-wrapper {
                width: 64px;
                height: 64px;
            }

            .pdf-icon-wrapper svg {
                width: 32px;
                height: 32px;
            }
        }
    </style>
</head>
