<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Stats Section</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Segoe UI', sans-serif;
  }

  .stats-section {
    background: #ffffff;
    padding: 80px 40px;
    position: relative;
    overflow: hidden;
  }

  .stats-section::before {
    content: '';
    position: absolute;
    top: -80px; left: -80px;
    width: 340px; height: 340px;
    border-radius: 50%;
    
    pointer-events: none;
  }
  .stats-section::after {
    content: '';
    position: absolute;
    bottom: -100px; right: -60px;
    width: 380px; height: 380px;
    border-radius: 50%;
    
    pointer-events: none;
  }

  .stats-grid {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 0;
    flex-wrap: wrap;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .stat-item {
    flex: 1;
    min-width: 200px;
    max-width: 270px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 30px 30px;
    position: relative;
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }

  .stat-item.visible { opacity: 1; transform: translateY(0); }
  .stat-item:nth-child(1) { transition-delay: 0.00s; }
  .stat-item:nth-child(2) { transition-delay: 0.12s; }
  .stat-item:nth-child(3) { transition-delay: 0.24s; }
  .stat-item:nth-child(4) { transition-delay: 0.36s; }

  .stat-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0; top: 8%;
    height: 84%; width: 1px;
    background: linear-gradient(to bottom, transparent, #aed4ce, transparent);
  }

  .icon-wrap {
    width: 74px; height: 74px;
    margin-bottom: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stat-number {
    font-size: 48px;
    font-weight: 700;
    color: #0d1f1d;
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -1.5px;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: 13px;
    font-weight: 700;
    color: #0e7a68;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .stat-desc {
    font-size: 11.5px;
    color: #6a8f8b;
    text-transform: uppercase;
    letter-spacing: 0.055em;
    line-height: 1.75;
    max-width: 155px;
  }

  /* ── Keyframes ── */

  /* Experience: dots pulse sequentially, arrow bounces */
  @keyframes dotPulse {
    0%, 80%, 100% { opacity: 1; transform: scale(1); }
    40% { opacity: 0.45; transform: scale(1.6); }
  }
  @keyframes arrowBounce {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(3px, -4px); }
  }

  .exp-dot { transform-origin: center; }
  .exp-dot-1 { animation: dotPulse 2.4s ease-in-out infinite 0.0s; }
  .exp-dot-2 { animation: dotPulse 2.4s ease-in-out infinite 0.3s; }
  .exp-dot-3 { animation: dotPulse 2.4s ease-in-out infinite 0.6s; }
  .exp-dot-4 { animation: dotPulse 2.4s ease-in-out infinite 0.9s; }
  .exp-dot-5 { animation: dotPulse 2.4s ease-in-out infinite 1.2s; }
  .exp-arrow  { animation: arrowBounce 1.8s ease-in-out infinite; transform-origin: 47px 16px; }

  /* Districts: pin drops, ripple expands */
  @keyframes pinBounce {
    0%, 100% { transform: translateY(0); }
    35%       { transform: translateY(-6px); }
    55%       { transform: translateY(-2px); }
    70%       { transform: translateY(-4px); }
  }
  @keyframes rippleOut {
    0%   { r: 3; opacity: 0.7; }
    100% { r: 13; opacity: 0; }
  }

  .map-pin   { animation: pinBounce 2.2s ease-in-out infinite; transform-origin: 31px 22px; }
  .ripple-1  { animation: rippleOut 2.2s ease-out infinite 0.1s; }
  .ripple-2  { animation: rippleOut 2.2s ease-out infinite 0.75s; }

  /* Families: each person sways */
  @keyframes sway {
    0%, 100% { transform: rotate(0deg); }
    30%       { transform: rotate(5deg); }
    70%       { transform: rotate(-4deg); }
  }

  .fam-dad   { animation: sway 2.6s ease-in-out infinite 0.0s;  transform-origin: 20px 20px; }
  .fam-mom   { animation: sway 2.6s ease-in-out infinite 0.5s;  transform-origin: 40px 21px; }
  .fam-child { animation: sway 2.6s ease-in-out infinite 0.25s; transform-origin: 30px 35px; }

  /* Employees: case bobs, shimmer sweeps */
  @keyframes caseBob {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    35%       { transform: translateY(-5px) rotate(-2deg); }
    65%       { transform: translateY(-2px) rotate(1.5deg); }
  }
  @keyframes sweepX {
    0%   { stroke-dashoffset: 40; opacity: 0.2; }
    50%  { opacity: 0.75; }
    100% { stroke-dashoffset: -40; opacity: 0.2; }
  }

  .emp-case   { animation: caseBob 2.5s ease-in-out infinite; transform-origin: 31px 38px; }
  .emp-sweep  { stroke-dasharray: 8 4; animation: sweepX 2.5s linear infinite; }

  @media (max-width: 700px) {
    .stats-grid { flex-direction: column; align-items: center; }
    .stat-item::after { display: none; }
    .stat-item { padding-bottom: 40px; border-bottom: 1px solid #c4deda; }
    .stat-item:last-child { border-bottom: none; }
  }
</style>
</head>
<body>
<section class="stats-section">
  <div class="stats-grid" id="statsGrid">

    <!-- Experience -->
    <div class="stat-item">
      <div class="icon-wrap">
        <svg width="72" height="72" viewBox="0 0 62 62" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="31" cy="31" r="28" fill="rgba(13,92,82,0.09)" stroke="rgba(13,92,82,0.18)" stroke-width="1"/>
          <polyline points="12,44 20,30 28,36 38,20 50,26"
            stroke="#0e7a68" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <line x1="10" y1="47" x2="52" y2="47" stroke="#0d5c52" stroke-width="1.4" stroke-linecap="round" opacity="0.3"/>
          <line x1="10" y1="47" x2="10" y2="15" stroke="#0d5c52" stroke-width="1.4" stroke-linecap="round" opacity="0.3"/>
          <circle class="exp-dot exp-dot-1" cx="12" cy="44" r="3" fill="#0d5c52"/>
          <circle class="exp-dot exp-dot-2" cx="20" cy="30" r="3" fill="#0d5c52"/>
          <circle class="exp-dot exp-dot-3" cx="28" cy="36" r="3" fill="#0e7a68"/>
          <circle class="exp-dot exp-dot-4" cx="38" cy="20" r="3" fill="#1a9e85"/>
          <circle class="exp-dot exp-dot-5" cx="50" cy="26" r="3" fill="#1a9e85"/>
          <g class="exp-arrow">
            <path d="M44 13 L50 13 L50 19" stroke="#1a9e85" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="42" y1="21" x2="50" y2="13" stroke="#1a9e85" stroke-width="2.1" stroke-linecap="round"/>
          </g>
        </svg>
      </div>
      <div class="stat-number"><span class="count" data-target="17">0</span>+</div>
      <div class="stat-label">Experience</div>
      <div class="stat-desc">of continuous innovation, devotion and dedication</div>
    </div>

    <!-- Districts — Bangladesh Map + animated pin -->
    <div class="stat-item">
      <div class="icon-wrap">
        <svg width="72" height="72" viewBox="0 0 62 62" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="31" cy="31" r="28" fill="rgba(13,92,82,0.09)" stroke="rgba(13,92,82,0.18)" stroke-width="1"/>
          <g transform="translate(14,8) scale(0.535)">
            <path d="M28 2 L32 4 L38 3 L44 6 L50 5 L56 10 L58 16 L55 22 L60 28 L58 34 L54 38 L52 44 L46 50 L42 56 L38 62 L34 66 L30 70 L26 66 L20 62 L16 58 L12 52 L8 48 L6 42 L2 38 L4 32 L8 26 L6 20 L10 14 L16 10 L22 6 Z"
              fill="rgba(26,158,133,0.2)" stroke="#0e7a68" stroke-width="2.2" stroke-linejoin="round"/>
            <line x1="30" y1="10" x2="30" y2="65" stroke="#0d5c52" stroke-width="1" opacity="0.22"/>
            <line x1="10" y1="36" x2="58" y2="36" stroke="#0d5c52" stroke-width="1" opacity="0.22"/>
            <line x1="14" y1="20" x2="48" y2="52" stroke="#0d5c52" stroke-width="0.8" opacity="0.15"/>
          </g>
          <!-- Ripples first (behind pin) -->
          <circle class="ripple-1" cx="31" cy="31" r="3" fill="none" stroke="#1a9e85" stroke-width="1.4"/>
          <circle class="ripple-2" cx="31" cy="31" r="3" fill="none" stroke="#1a9e85" stroke-width="1"/>
          <!-- Animated pin -->
          <g class="map-pin">
            <path d="M31 14 C27.5 14 24.5 17 24.5 20.5 C24.5 25.5 31 33 31 33 C31 33 37.5 25.5 37.5 20.5 C37.5 17 34.5 14 31 14 Z"
              fill="#1a9e85" stroke="#0d5c52" stroke-width="1"/>
            <circle cx="31" cy="20.5" r="3" fill="white" opacity="0.9"/>
          </g>
        </svg>
      </div>
      <div class="stat-number"><span class="count" data-target="64">0</span></div>
      <div class="stat-label">Districts</div>
      <div class="stat-desc">covered with an ever growing network</div>
    </div>

    <!-- Families -->
    <div class="stat-item">
      <div class="icon-wrap">
        <svg width="72" height="72" viewBox="0 0 62 62" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="31" cy="31" r="28" fill="rgba(13,92,82,0.09)" stroke="rgba(13,92,82,0.18)" stroke-width="1"/>
          <g class="fam-dad">
            <circle cx="20" cy="19" r="5.2" stroke="#0d5c52" stroke-width="2" fill="none"/>
            <path d="M9 43 C9 35 14 30 20 30 C26 30 31 35 31 43" stroke="#0d5c52" stroke-width="2" fill="none" stroke-linecap="round"/>
          </g>
          <g class="fam-mom">
            <circle cx="40" cy="20" r="4.4" stroke="#0e7a68" stroke-width="2" fill="none"/>
            <path d="M30 43 C30 36 34.5 32 40 32 C45.5 32 50 36 50 43" stroke="#0e7a68" stroke-width="2" fill="none" stroke-linecap="round"/>
          </g>
          <g class="fam-child">
            <circle cx="30" cy="35" r="3" stroke="#1a9e85" stroke-width="1.8" fill="none"/>
            <path d="M25 47 C25 43.5 27 41.5 30 41.5 C33 41.5 35 43.5 35 47" stroke="#1a9e85" stroke-width="1.8" fill="none" stroke-linecap="round"/>
          </g>
        </svg>
      </div>
      <div class="stat-number"><span class="count" data-target="20">0</span>M</div>
      <div class="stat-label">Families</div>
      <div class="stat-desc">and homes enlightened with our products</div>
    </div>

    <!-- Employees -->
    <div class="stat-item">
      <div class="icon-wrap">
        <svg width="72" height="72" viewBox="0 0 62 62" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="31" cy="31" r="28" fill="rgba(13,92,82,0.09)" stroke="rgba(13,92,82,0.18)" stroke-width="1"/>
          <g class="emp-case">
            <rect x="13" y="26" width="36" height="24" rx="3" stroke="#0d5c52" stroke-width="2" fill="rgba(13,92,82,0.07)"/>
            <path d="M22 26 L22 20 C22 18 40 18 40 20 L40 26" stroke="#0e7a68" stroke-width="2" fill="none" stroke-linejoin="round"/>
            <rect x="26" y="34" width="10" height="7" rx="1.5" stroke="#1a9e85" stroke-width="1.8" fill="none"/>
            <line x1="26" y1="37.5" x2="36" y2="37.5" stroke="#1a9e85" stroke-width="1.3" opacity="0.55"/>
          </g>
          <line class="emp-sweep" x1="16" y1="38" x2="46" y2="38" stroke="#1a9e85" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="stat-number"><span class="count" data-target="1150">0</span>+</div>
      <div class="stat-label">Employees</div>
      <div class="stat-desc">working in hopes and dreams to make a difference</div>
    </div>

  </div>
</section>

<script>
  function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }

  function animateCount(el) {
    const target = parseInt(el.dataset.target);
    const duration = 2000;
    const start = performance.now();
    function step(now) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      el.textContent = Math.floor(easeOutCubic(progress) * target).toLocaleString();
      if (progress < 1) requestAnimationFrame(step);
      else el.textContent = target.toLocaleString();
    }
    requestAnimationFrame(step);
  }

  let animated = false;
  const grid = document.getElementById('statsGrid');
  const items = document.querySelectorAll('.stat-item');

  const trigger = () => {
    if (animated) return;
    animated = true;
    items.forEach(item => item.classList.add('visible'));
    setTimeout(() => document.querySelectorAll('.count').forEach(animateCount), 300);
  };

  new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) { trigger(); }
  }, { threshold: 0.2 }).observe(grid);

  window.addEventListener('load', () => {
    if (grid.getBoundingClientRect().top < window.innerHeight) trigger();
  });
</script>
</body>
</html>
