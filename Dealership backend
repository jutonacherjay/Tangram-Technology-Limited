        'district'      => 'জেলা',
        'business_type' => 'ব্যবসার ধরণ',
        'monthly_sales' => 'মাসিক বিক্রয়',
        'date'          => 'তারিখ',
    );
}

add_action( 'manage_dealer_request_posts_custom_column', 'tangram_dealer_column_data', 10, 2 );
function tangram_dealer_column_data( $column, $post_id ) {
    $map = array(
        'mobile'        => '_mobile',
        'shop_name'     => '_shop_name',
        'district'      => '_district',
        'business_type' => '_business_type',
        'monthly_sales' => '_monthly_sales',
    );
    if ( isset( $map[ $column ] ) ) {
        echo esc_html( get_post_meta( $post_id, $map[ $column ], true ) );
    }
}


// ৩. META BOX — আবেদনের ভেতরে সব তথ্য
