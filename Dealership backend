// ১. CUSTOM POST TYPE
add_action( 'init', 'tangram_register_dealer_cpt' );
function tangram_register_dealer_cpt() {
    register_post_type( 'dealer_request', array(
        'labels' => array(
            'name'          => 'Dealer Requests',
            'singular_name' => 'Dealer Request',
            'menu_name'     => 'Dealer Requests',
            'not_found'     => 'কোনো আবেদন পাওয়া যায়নি',
        ),
        'public'       => false,
        'show_ui'      => true,
        'show_in_menu' => true,
        'menu_icon'    => 'dashicons-store',
        'supports'     => array( 'title' ),
        'has_archive'  => false,
    ));
}


// ২. ADMIN LIST কলাম
