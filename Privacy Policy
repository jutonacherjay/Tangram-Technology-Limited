<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Privacy Policy - Tangram Electronics</title>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #10B981;
            --primary-dark: #059669;
            --primary-light: #34D399;
            --accent: #3B82F6;
            --accent-light: #60A5FA;
            --text: #1A1A2E;
            --text-light: #64748B;
            --bg: #FAFAFA;
            --card: #FFFFFF;
            --border: #E2E8F0;
            --gradient: linear-gradient(135deg, #10B981 0%, #34D399 100%);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Work Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
            overflow-x: hidden;
        }

        /* Animated Background */
        .bg-decoration {
            position: fixed;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .bg-shape {
            position: absolute;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.05), rgba(59, 130, 246, 0.05));
            animation: float-bg 25s ease-in-out infinite;
        }

        .bg-shape-1 {
            width: 600px;
            height: 600px;
            top: -200px;
            right: -100px;
            animation-delay: 0s;
        }

        .bg-shape-2 {
            width: 400px;
            height: 400px;
            bottom: -100px;
            left: -50px;
            animation-delay: -10s;
        }

        @keyframes float-bg {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(50px, -50px) rotate(120deg); }
            66% { transform: translate(-30px, 30px) rotate(240deg); }
        }

        /* Header Section */
        .header {
            position: relative;
            z-index: 1;
            padding: 100px 0 80px;
            text-align: center;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(250, 250, 250, 0.8) 100%);
            backdrop-filter: blur(10px);
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .header-badge {
            display: inline-block;
            padding: 10px 24px;
            background: rgba(16, 185, 129, 0.1);
            border: 2px solid rgba(16, 185, 129, 0.2);
            border-radius: 50px;
            color: var(--primary);
            font-weight: 600;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 24px;
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards;
        }

        .page-title {
            font-family: 'Crimson Pro', serif;
            font-size: clamp(48px, 6vw, 72px);
            font-weight: 700;
            color: var(--text);
            margin-bottom: 24px;
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards 0.2s;
        }

        .page-subtitle {
            font-size: clamp(16px, 2vw, 20px);
            color: var(--text-light);
            max-width: 700px;
            margin: 0 auto 40px;
            line-height: 1.6;
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards 0.4s;
        }

        .cta-button {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 16px 36px;
            background: var(--gradient);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 16px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 8px 24px rgba(16, 185, 129, 0.3);
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards 0.6s;
            position: relative;
            overflow: hidden;
        }

        .cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transition: left 0.6s;
        }

        .cta-button:hover::before {
            left: 100%;
        }

        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 32px rgba(16, 185, 129, 0.4);
        }

        .cta-button svg {
            width: 20px;
            height: 20px;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Content Section */
        .content-section {
            position: relative;
            z-index: 1;
            padding: 60px 0 100px;
        }

        .intro-text {
            background: var(--card);
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            margin-bottom: 40px;
            border-left: 4px solid var(--primary);
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards 0.8s;
        }

        .intro-text p {
            font-size: 17px;
            line-height: 1.8;
            color: var(--text-light);
        }

        .intro-text a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }

        .intro-text a:hover {
            color: var(--primary-dark);
        }

        /* Accordion Sections */
        .accordion {
            margin-top: 40px;
        }

        .accordion-item {
            background: var(--card);
            border-radius: 16px;
            margin-bottom: 20px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
            transition: all 0.3s ease;
            opacity: 0;
            animation: fadeInUp 0.6s ease forwards;
        }

        .accordion-item:nth-child(1) { animation-delay: 1s; }
        .accordion-item:nth-child(2) { animation-delay: 1.1s; }
        .accordion-item:nth-child(3) { animation-delay: 1.2s; }
        .accordion-item:nth-child(4) { animation-delay: 1.3s; }
        .accordion-item:nth-child(5) { animation-delay: 1.4s; }
        .accordion-item:nth-child(6) { animation-delay: 1.5s; }
        .accordion-item:nth-child(7) { animation-delay: 1.6s; }

        .accordion-item:hover {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
            transform: translateY(-2px);
        }

        .accordion-item.active {
            box-shadow: 0 8px 32px rgba(16, 185, 129, 0.15);
        }

        .accordion-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 28px 32px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }

        .accordion-header::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background: var(--gradient);
            transform: scaleY(0);
            transition: transform 0.3s ease;
        }

        .accordion-item.active .accordion-header::before {
            transform: scaleY(1);
        }

        .accordion-title {
            display: flex;
            align-items: center;
            gap: 16px;
            font-family: 'Crimson Pro', serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
        }

        .accordion-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(52, 211, 153, 0.1));
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .accordion-item.active .accordion-icon {
            background: var(--gradient);
            transform: rotate(5deg) scale(1.05);
        }

        .accordion-icon svg {
            width: 24px;
            height: 24px;
            stroke: var(--primary);
            transition: stroke 0.3s ease;
        }

        .accordion-item.active .accordion-icon svg {
            stroke: white;
        }

        .accordion-toggle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(16, 185, 129, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .accordion-toggle svg {
            width: 20px;
            height: 20px;
            stroke: var(--primary);
            transition: transform 0.3s ease;
        }

        .accordion-item.active .accordion-toggle {
            background: var(--primary);
            transform: rotate(180deg);
        }

        .accordion-item.active .accordion-toggle svg {
            stroke: white;
        }

        .accordion-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .accordion-item.active .accordion-content {
            max-height: 1000px;
        }

        .accordion-body {
            padding: 0 32px 32px 96px;
            color: var(--text-light);
            font-size: 16px;
            line-height: 1.8;
        }

        .accordion-body ul {
            list-style: none;
            margin-top: 16px;
        }

        .accordion-body li {
            padding: 12px 0 12px 32px;
            position: relative;
        }

        .accordion-body li::before {
            content: '→';
            position: absolute;
            left: 0;
            color: var(--primary);
            font-weight: 700;
        }

        .accordion-body strong {
            color: var(--text);
            font-weight: 600;
        }

        /* Contact Card */
        .contact-card {
            background: linear-gradient(135deg, #10B981 0%, #3B82F6 100%);
            padding: 50px 40px;
            border-radius: 20px;
            margin-top: 60px;
            text-align: center;
            color: white;
            position: relative;
            overflow: hidden;
            opacity: 0;
            animation: fadeInUp 0.8s ease forwards 1.8s;
        }

        .contact-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="100" height="100" patternUnits="userSpaceOnUse"><path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(%23grid)"/></svg>');
        }

        .contact-card-content {
            position: relative;
            z-index: 1;
        }

        .contact-card h3 {
            font-family: 'Crimson Pro', serif;
            font-size: 32px;
            margin-bottom: 16px;
        }

        .contact-card p {
            font-size: 18px;
            margin-bottom: 30px;
            opacity: 0.9;
        }

        .contact-info {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 24px;
            margin-top: 24px;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border-radius: 50px;
            transition: all 0.3s ease;
        }

        .contact-item:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: translateY(-2px);
        }

        .contact-item svg {
            width: 20px;
            height: 20px;
        }

        .contact-item a {
            color: white;
            text-decoration: none;
            font-weight: 600;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header {
                padding: 60px 0 40px;
            }

            .container {
                padding: 0 16px;
            }

            .accordion-header {
                padding: 20px 20px;
            }

            .accordion-title {
                font-size: 18px;
                gap: 12px;
            }

            .accordion-icon {
                width: 40px;
                height: 40px;
            }

            .accordion-icon svg {
                width: 20px;
                height: 20px;
            }

            .accordion-body {
                padding: 0 20px 24px 72px;
                font-size: 15px;
            }

            .intro-text {
                padding: 24px 20px;
            }

            .contact-card {
                padding: 40px 24px;
            }

            .contact-info {
                flex-direction: column;
                align-items: stretch;
            }

            .contact-item {
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- Background Decoration -->
    <div class="bg-decoration">
