  function t(k){return T[k]?T[k][lang]:k;}

  /* ── Apply language ── */
  function applyLang(){
    /* data-bn / data-en */
    document.querySelectorAll('[data-bn]').forEach(function(el){
      el.textContent=lang==='bn'?el.getAttribute('data-bn'):el.getAttribute('data-en');
    });
    /* section titles */
    var st=document.querySelectorAll('.tdr-sec-title');
    ['sec-1','sec-2','sec-3','sec-4','sec-5','sec-6','sec-7','sec-8','sec-9'].forEach(function(k,i){if(st[i])st[i].textContent=t(k);});
    /* field labels */
    var lblMap={'full_name':'lbl-full_name','mobile':'lbl-mobile','shop_name':'lbl-shop_name','business_type':'lbl-business_type','years_in_business':'lbl-years','district':'lbl-district','upazila':'lbl-upazila','full_address':'lbl-address','sells_electrical':'lbl-sells','current_brands':'lbl-brands','shop_size':'lbl-shop_size','employees':'lbl-employees','monthly_sales':'lbl-monthly','interested_products[]':'lbl-products','investment':'lbl-investment','comments':'lbl-comments'};
    Object.keys(lblMap).forEach(function(name){
      var inp=document.querySelector('[name="'+name+'"]');
      if(!inp)return;
      var lbl=inp.closest('.tdr-field').querySelector('label');
      if(!lbl)return;
      var req=lbl.querySelector('.req');
      lbl.textContent=t(lblMap[name]);
      if(req)lbl.appendChild(req);
    });
    /* file box labels */
    [{n:'shop_photo',k:'ph-shop_photo'},{n:'nid_copy',k:'ph-nid'},{n:'trade_license',k:'ph-trade'}].forEach(function(item){
      var inp=document.querySelector('[name="'+item.n+'"]');
      if(!inp)return;
      var box=inp.closest('.tdr-file');
      if(!box)return;
      box.childNodes.forEach(function(node){if(node.nodeType===3&&node.textContent.trim())node.textContent=' '+t(item.k)+' ';});
    });
    /* file labels above box */
    [{n:'shop_photo',k:'lbl-shop_photo'},{n:'nid_copy',k:'lbl-nid'},{n:'trade_license',k:'lbl-trade'}].forEach(function(item){
      var inp=document.querySelector('[name="'+item.n+'"]');
      if(!inp)return;
      var field=inp.closest('.tdr-field');
      if(!field)return;
      var lbl=field.querySelector('label:not(.tdr-file)');
      if(!lbl)return;
      var req=lbl.querySelector('.req');
      var opt=lbl.querySelector('span[style]');
      lbl.textContent=t(item.k)+' ';
      if(req)lbl.appendChild(req);
      if(opt){opt.textContent=t('optional');lbl.appendChild(opt);}
    });
    /* optional span */
    document.querySelectorAll('label span[style]').forEach(function(el){el.textContent=t('optional');});
    /* note */
    document.querySelectorAll('.tdr-note').forEach(function(el){el.textContent=t('file-note');});
    /* placeholders */
    var phMap={'full_name':'ph-full_name','mobile':'ph-mobile','shop_name':'ph-shop_name','district':'ph-district','upazila':'ph-upazila','full_address':'ph-address','current_brands':'ph-brands','shop_size':'ph-shop_size','employees':'ph-employees','comments':'ph-comments'};
    Object.keys(phMap).forEach(function(name){var el=document.querySelector('[name="'+name+'"]');if(el)el.placeholder=t(phMap[name]);});
    /* option labels */
    var optMap=[
      {val:'খুচরা দোকান (Retail)',k:'opt-retail'},{val:'পাইকারি দোকান (Wholesale)',k:'opt-wholesale'},
      {val:'ডিস্ট্রিবিউটর',k:'opt-dist'},{val:'অনলাইন বিক্রেতা',k:'opt-online'},
      {val:'১ বছরের কম',k:'opt-y1'},{val:'১–৩ বছর',k:'opt-y13'},{val:'৩–৫ বছর',k:'opt-y35'},{val:'৫ বছরের বেশি',k:'opt-y5'},
      {val:'হ্যাঁ',k:'opt-yes'},{val:'না',k:'opt-no'},
      {val:'৫০,০০০–১,০০,০০০ টাকা',k:'opt-s1'},{val:'১,০০,০০০–৩,০০,০০০ টাকা',k:'opt-s2'},{val:'৩,০০,০০০–৫,০০,০০০ টাকা',k:'opt-s3'},{val:'৫,০০,০০০ টাকার বেশি',k:'opt-s4'},
      {val:'এক্সটেনশন সকেট',k:'opt-p1'},{val:'মাল্টিপ্লাগ',k:'opt-p2'},{val:'ইলেকট্রিক্যাল এক্সেসরিজ',k:'opt-p3'},{val:'সবগুলো',k:'opt-p4'},
      {val:'৫০,০০০–১ লক্ষ টাকা (সর্বনিম্ন)',k:'opt-i1'},{val:'১–৩ লক্ষ টাকা',k:'opt-i2'},{val:'৩–৫ লক্ষ টাকা',k:'opt-i3'},{val:'৫ লক্ষ টাকার বেশি',k:'opt-i4'},
    ];
    optMap.forEach(function(item){
      var inp=document.querySelector('[value="'+item.val+'"]');
      if(!inp)return;
      var opt=inp.closest('.tdr-opt');
      if(!opt)return;
      opt.childNodes.forEach(function(node){if(node.nodeType===3&&node.textContent.trim())node.textContent=' '+t(item.k);});
    });
    /* submit btn */
    var st2=document.getElementById('tdr-sub-txt');
    if(st2)st2.textContent=t('submit-btn');
    /* lang toggle */
    var ll=document.getElementById('tdr-lang-label');
    if(ll)ll.textContent=lang==='bn'?'English':'বাংলা';
    var lf=document.querySelector('.tdr-lang-flag');
    if(lf)lf.textContent=lang==='bn'?'🇬🇧':'🇧🇩';
  }

  window.tdrToggleLang=function(){lang=lang==='bn'?'en':'bn';applyLang();};

  /* ── Radio/Checkbox visual ── */
  document.querySelectorAll('#tdr-form .tdr-opt input').forEach(function(inp){
    inp.addEventListener('change',function(){
      var name=this.name;
      if(this.type==='radio'){
        document.querySelectorAll('[name="'+name+'"]').forEach(function(r){r.closest('.tdr-opt').classList.toggle('sel',r.checked);});
      } else {
        this.closest('.tdr-opt').classList.toggle('sel',this.checked);
      }
    });
  });

  /* ── File name display ── */
  ['shop_photo','nid_copy','trade_license'].forEach(function(f,idx){
    var inp=document.querySelector('[name="'+f+'"]');
    if(!inp)return;
    inp.addEventListener('change',function(){
      var el=document.getElementById('tdr-fn'+(idx+1));
      if(el)el.textContent=this.files[0]?this.files[0].name:'';
    });
  });

  /* ── Error ── */
  function showErr(msg){
    var e=document.getElementById('tdr-err-main');
    e.textContent=msg;e.style.display='block';
    e.scrollIntoView({behavior:'smooth',block:'nearest'});
    setTimeout(function(){e.style.display='none';},4000);
  }

  /* ── Submit ── */
  document.getElementById('tdr-form').addEventListener('submit',function(e){
    e.preventDefault();
    var f=this;
    var btn=document.getElementById('tdr-sub-btn');
    var txt=document.getElementById('tdr-sub-txt');
    var spin=document.getElementById('tdr-sub-spin');

    if(!f.querySelector('[name="full_name"]').value.trim()||!f.querySelector('[name="mobile"]').value.trim()){showErr(t('err-name'));return;}
    if(!f.querySelector('[name="shop_name"]').value.trim()){showErr(t('err-shop'));return;}
    if(!f.querySelector('[name="business_type"]:checked')){showErr(t('err-btype'));return;}
    if(!f.querySelector('[name="years_in_business"]:checked')){showErr(t('err-years'));return;}
    if(!f.querySelector('[name="district"]').value.trim()||!f.querySelector('[name="full_address"]').value.trim()){showErr(t('err-addr'));return;}
    if(!f.querySelector('[name="sells_electrical"]:checked')){showErr(t('err-elec'));return;}
    if(!f.querySelector('[name="monthly_sales"]:checked')){showErr(t('err-sales'));return;}
    if(!f.querySelector('[name="interested_products[]"]:checked')){showErr(t('err-prod'));return;}
    if(!f.querySelector('[name="investment"]:checked')){showErr(t('err-inv'));return;}

    var products=[];
    f.querySelectorAll('[name="interested_products[]"]:checked').forEach(function(c){products.push(c.value);});

    var fd=new FormData();
    fd.append('action','tangram_dealer_submit');
    fd.append('nonce',(typeof tangramAjax!=='undefined')?tangramAjax.nonce:'');
    fd.append('full_name',f.querySelector('[name="full_name"]').value.trim());
    fd.append('mobile',f.querySelector('[name="mobile"]').value.trim());
    fd.append('shop_name',f.querySelector('[name="shop_name"]').value.trim());
    fd.append('business_type',f.querySelector('[name="business_type"]:checked').value);
    fd.append('years_in_business',f.querySelector('[name="years_in_business"]:checked').value);
    fd.append('district',f.querySelector('[name="district"]').value.trim());
    fd.append('upazila',f.querySelector('[name="upazila"]').value.trim());
    fd.append('full_address',f.querySelector('[name="full_address"]').value.trim());
    fd.append('sells_electrical',f.querySelector('[name="sells_electrical"]:checked').value);
    fd.append('current_brands',f.querySelector('[name="current_brands"]').value.trim());
    fd.append('shop_size',f.querySelector('[name="shop_size"]').value.trim());
    fd.append('employees',f.querySelector('[name="employees"]').value.trim());
    fd.append('monthly_sales',f.querySelector('[name="monthly_sales"]:checked').value);
    fd.append('interested_products',products.join(', '));
    fd.append('investment',f.querySelector('[name="investment"]:checked').value);
    fd.append('comments',f.querySelector('[name="comments"]').value.trim());

    ['shop_photo','nid_copy','trade_license'].forEach(function(fl){
      var fi=f.querySelector('[name="'+fl+'"]');
      if(fi&&fi.files[0])fd.append(fl,fi.files[0]);
    });

    btn.disabled=true;txt.style.display='none';spin.style.display='block';

    var url=(typeof tangramAjax!=='undefined')?tangramAjax.url:'/wp-admin/admin-ajax.php';

    fetch(url,{method:'POST',body:fd})
      .then(function(r){return r.json();})
      .then(function(res){
        if(res.success){
          document.getElementById('tdr-form').style.display='none';
          document.getElementById('tdr-success').style.display='block';
          window.scrollTo({top:0,behavior:'smooth'});
        } else {
          showErr(res.data||t('err-gen'));
          btn.disabled=false;txt.style.display='inline';spin.style.display='none';
        }
      })
      .catch(function(){
        showErr(t('err-net'));
        btn.disabled=false;txt.style.display='inline';spin.style.display='none';
      });
  });

})();
</script>
