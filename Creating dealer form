<style>
@import url('https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;500;600;700&family=Noto+Serif+Bengali:wght@600;700&display=swap');

*{box-sizing:border-box;margin:0;padding:0}

:root{
  --mint:#e8f8f5;
  --lt:#c8f2ec;
  --st:#b2ece3;
  --teal:#2ecfb0;
  --deep:#0a9e84;
  --dark:#077d68;
  --ink:#0d2e28;
  --ink2:#2a5a52;
  --ink3:#4a8a80;
  --r:10px;
  --r2:16px;
}

/* ── OUTER WRAPPER ── */
#tdr-outer{
  width:100%;
  background:var(--mint);
  font-family:'Hind Siliguri',sans-serif;
  color:var(--ink);
}

/* ── HERO ── */
.tdr-hero{
  background:linear-gradient(135deg,#0a9e84 0%,#077d68 100%);
  border-radius:var(--r2);
  padding:24px 20px 22px;
  margin:16px 16px 0;
  position:relative;
  overflow:hidden;
}
.tdr-hero::after{
  content:'';position:absolute;right:-30px;top:-30px;
  width:160px;height:160px;border-radius:50%;
  background:rgba(255,255,255,.07);pointer-events:none;
}
.tdr-hero-inner{position:relative}
.tdr-hero-left{width:100%}
.tdr-badge{
  display:inline-flex;align-items:center;gap:5px;
  background:rgba(255,255,255,.15);
  border:1px solid rgba(255,255,255,.25);
  border-radius:50px;padding:4px 12px;
  font-size:11px;color:#fff;font-weight:500;
  margin-bottom:12px;letter-spacing:.4px;
}
.tdr-badge-dot{width:6px;height:6px;border-radius:50%;background:#b2ece3;flex-shrink:0}
.tdr-hero h1{
  font-family:'Noto Serif Bengali',serif;
  font-size:clamp(18px,5vw,26px);
  font-weight:700;color:#fff;line-height:1.4;margin-bottom:8px;
}
.tdr-hero p{
  font-size:clamp(12px,3.5vw,13.5px);
  color:rgba(255,255,255,.75);line-height:1.7;
}
.tdr-hero-bar{width:36px;height:3px;background:#b2ece3;border-radius:2px;margin-top:14px}
@media(min-width:768px){
  .tdr-hero{margin:24px 24px 0;padding:36px 44px 32px}
}
@media(min-width:960px){
  .tdr-hero{margin:32px auto 0;max-width:900px;padding:40px 48px 36px}
}

/* ── FORM CONTAINER — centered, max-width ── */
#tdr-wrap{
  width:100%;
  max-width:900px;
  margin:0 auto;
  padding:28px 16px 64px;
}
@media(min-width:600px){#tdr-wrap{padding:36px 24px 80px}}
@media(min-width:960px){#tdr-wrap{padding:48px 32px 100px}}

/* ── SECTION ── */
.tdr-section{
  background:#fff;
  border-radius:var(--r2);
  border:1px solid var(--lt);
  margin-bottom:16px;
  overflow:hidden;
}
@media(min-width:768px){.tdr-section{margin-bottom:20px;border-radius:20px}}

.tdr-sec-head{
  display:flex;align-items:center;gap:12px;
  padding:13px 18px;
  background:var(--mint);
  border-bottom:1px solid var(--lt);
}
@media(min-width:768px){.tdr-sec-head{padding:15px 24px}}

.tdr-sec-num{
  width:26px;height:26px;border-radius:50%;
  background:var(--deep);color:#fff;
  font-size:11px;font-weight:700;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
@media(min-width:768px){.tdr-sec-num{width:28px;height:28px;font-size:12px}}

.tdr-sec-title{font-size:13px;font-weight:600;color:var(--ink2)}
@media(min-width:768px){.tdr-sec-title{font-size:14px}}

.tdr-sec-body{padding:16px}
@media(min-width:768px){.tdr-sec-body{padding:22px 24px}}
@media(min-width:960px){.tdr-sec-body{padding:26px 28px}}

/* ── GRID ── */
.tdr-grid{display:grid;grid-template-columns:1fr;gap:14px}
.tdr-span2{grid-column:1/-1}
@media(min-width:480px){
  .tdr-grid.cols2{grid-template-columns:1fr 1fr}
}
@media(min-width:768px){
  .tdr-grid{gap:18px}
  .tdr-grid.cols3{grid-template-columns:1fr 1fr 1fr}
}

/* ── FIELD ── */
.tdr-field{display:flex;flex-direction:column;gap:6px}
.tdr-field label{
  font-size:12.5px;font-weight:600;
  color:var(--ink2);line-height:1.4;
}
@media(min-width:768px){.tdr-field label{font-size:13px}}
.tdr-field label .req{color:var(--deep);margin-left:2px}

.tdr-field input,
.tdr-field textarea{
  width:100%;
  padding:8px 13px;
  border:1.5px solid #d0ede8;
  border-radius:var(--r);
  font-family:'Hind Siliguri',sans-serif;
  font-size:14px;color:var(--ink);
  background:#fff;outline:none;
  -webkit-appearance:none;
  transition:border .18s,box-shadow .18s;
  min-height:38px;
}
@media(min-width:768px){
  .tdr-field input,.tdr-field textarea{
    padding:9px 16px;font-size:14.5px;min-height:42px;
  }
}
.tdr-field input:focus,
.tdr-field textarea:focus{
  border-color:var(--teal);
  box-shadow:0 0 0 3px rgba(46,207,176,.14);
}
.tdr-field textarea{resize:vertical;min-height:100px;line-height:1.65}

/* ── OPTIONS ── */
.tdr-opts{display:flex;flex-direction:column;gap:8px}
.tdr-opts.horiz{flex-direction:row;flex-wrap:wrap}

.tdr-opt{
  display:flex;align-items:center;gap:10px;
  padding:11px 14px;
  border:1.5px solid #d0ede8;
  border-radius:var(--r);
  cursor:pointer;font-size:13.5px;
  color:var(--ink2);
  transition:all .18s;user-select:none;
  min-height:44px;
  -webkit-tap-highlight-color:transparent;
}
@media(min-width:768px){
  .tdr-opt{padding:12px 18px;font-size:14px;min-height:48px}
}
.tdr-opt:hover{border-color:var(--teal);background:#f0fdfb}
.tdr-opt input{
  appearance:none;-webkit-appearance:none;
  width:7px;height:7px;min-width:7px;
  border:1.5px solid #b2ece3;
  border-radius:8px;
  flex-shrink:0;cursor:pointer;
  position:relative;
  background:#fff;
  transition:background .15s,border-color .15s;
}
.tdr-opt input:checked{
  background:var(--deep);
  border-color:var(--deep);
  animation:tdr-pop .18s cubic-bezier(.34,1.56,.64,1);
}
@keyframes tdr-pop{
  0%{transform:scale(.5)}
  100%{transform:scale(1)}
}
.tdr-opt input:checked::after{
  content:'';display:block;
  width:2px;height:4px;
  border-right:1.2px solid #fff;
  border-bottom:1.2px solid #fff;
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-65%) rotate(45deg);
}
.tdr-opt.sel{border-color:var(--deep);background:#e6faf6;color:var(--dark);font-weight:600}

/* ── FILE ── */
.tdr-file{
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:6px;
  border:2px dashed #b2ece3;border-radius:var(--r);
  padding:20px 16px;cursor:pointer;
  transition:all .18s;text-align:center;
  color:var(--ink3);font-size:13px;
  min-height:100px;
  -webkit-tap-highlight-color:transparent;
}
@media(min-width:768px){.tdr-file{padding:28px 20px;min-height:120px;font-size:13.5px}}
.tdr-file:hover,.tdr-file:active{border-color:var(--deep);background:#f0fdfb}
.tdr-file input{display:none}
.tdr-file-icon{
  width:38px;height:38px;background:var(--lt);
  border-radius:9px;display:flex;align-items:center;justify-content:center;
}
.tdr-file-icon svg{width:18px;height:18px;stroke:var(--deep);fill:none;stroke-width:2}
.tdr-fname{font-size:11.5px;color:var(--deep);font-weight:600;margin-top:2px;word-break:break-all}

/* ── SUBMIT ── */
.tdr-submit-wrap{text-align:center;margin-top:10px}
.tdr-btn-submit{
  display:block;width:100%;
  background:var(--deep);color:#fff;border:none;
  padding:16px 24px;
  font-family:'Hind Siliguri',sans-serif;
  font-size:16px;font-weight:700;
  border-radius:50px;cursor:pointer;
  transition:all .2s;
  box-shadow:0 4px 20px rgba(10,158,132,.35);
  letter-spacing:.3px;min-height:52px;
  -webkit-tap-highlight-color:transparent;
}
@media(min-width:480px){
  .tdr-btn-submit{width:auto;display:inline-block;padding:16px 64px;font-size:17px}
}
@media(min-width:768px){
  .tdr-btn-submit{padding:18px 80px;font-size:18px;min-height:58px}
}
.tdr-btn-submit:hover{background:var(--dark);transform:translateY(-2px);box-shadow:0 8px 28px rgba(7,125,104,.4)}
.tdr-btn-submit:active{transform:scale(.98)}
.tdr-btn-submit:disabled{background:#a0d8d0;box-shadow:none;cursor:not-allowed;transform:none}

/* ── SPINNER ── */
.tdr-spin{
  display:none;width:20px;height:20px;
  border:2.5px solid rgba(255,255,255,.4);
  border-top-color:#fff;border-radius:50%;
  animation:tdr-rot .7s linear infinite;margin:0 auto;
}
@keyframes tdr-rot{to{transform:rotate(360deg)}}

/* ── ERROR ── */
.tdr-err{
  display:none;background:#fff0f1;
  border:1.5px solid #f5a0a8;border-radius:var(--r);
  padding:12px 18px;font-size:13.5px;
  color:#b52832;margin-top:16px;text-align:center;line-height:1.5;
}

/* ── SUCCESS ── */
.tdr-success{
  display:none;background:#fff;
  border-radius:var(--r2);border:1px solid var(--lt);
  padding:48px 24px;text-align:center;
}
@media(min-width:768px){.tdr-success{padding:72px 48px}}
.tdr-success-icon{
  width:72px;height:72px;
  background:linear-gradient(135deg,var(--teal),var(--deep));
  border-radius:50%;display:flex;align-items:center;
  justify-content:center;margin:0 auto 20px;
}
.tdr-success-icon svg{width:32px;height:32px;stroke:#fff;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.tdr-success h2{font-family:'Noto Serif Bengali',serif;font-size:clamp(20px,4vw,26px);color:var(--dark);margin-bottom:12px}
.tdr-success p{font-size:clamp(13px,2vw,15px);color:var(--ink2);line-height:1.8;max-width:440px;margin:0 auto}
.tdr-success-badge{
  display:inline-block;background:var(--mint);
  border:1px solid var(--st);border-radius:50px;
  padding:8px 24px;font-size:clamp(12px,2vw,13.5px);
  color:var(--deep);font-weight:600;margin-top:20px;line-height:1.5;
}
.tdr-note{font-size:11.5px;color:var(--ink3);margin-top:8px;line-height:1.5}

/* ── LANGUAGE TOGGLE ── */
.tdr-lang-wrap{
  position:absolute;top:16px;right:16px;z-index:10;
}
@media(min-width:768px){.tdr-lang-wrap{top:20px;right:24px}}
.tdr-lang-btn{
  display:flex;align-items:center;gap:6px;
  background:rgba(255,255,255,.18);
  border:1px solid rgba(255,255,255,.3);
  border-radius:50px;padding:5px 12px;
  font-family:'Hind Siliguri',sans-serif;
  font-size:12px;font-weight:600;color:#fff;
  cursor:pointer;transition:all .18s;
  -webkit-tap-highlight-color:transparent;
}
.tdr-lang-btn:hover{background:rgba(255,255,255,.28)}
.tdr-lang-flag{font-size:14px}

/* ── ADVANTAGE BUTTON ── */
.tdr-adv-btn{
  display:inline-flex;align-items:center;gap:8px;
  margin-top:20px;
  background:var(--deep);color:#fff;
  border:none;border-radius:50px;
  padding:12px 28px;
  font-family:'Hind Siliguri',sans-serif;
  font-size:14px;font-weight:600;
  cursor:pointer;transition:all .18s;
  box-shadow:0 4px 14px rgba(10,158,132,.3);
  -webkit-tap-highlight-color:transparent;
}
.tdr-adv-btn:hover{background:var(--dark);transform:translateY(-1px)}
.tdr-adv-btn svg{width:16px;height:16px;stroke:#fff;fill:none;stroke-width:2;flex-shrink:0}

/* ── ADVANTAGE MODAL ── */
.tdr-modal-overlay{
  display:none;
  position:fixed;inset:0;
  background:rgba(10,46,40,.55);
  z-index:9999;
  align-items:center;justify-content:center;
  padding:16px;
}
.tdr-modal-overlay.open{display:flex}
.tdr-modal{
  background:#fff;
  border-radius:20px;
  max-width:560px;width:100%;
  max-height:90vh;overflow-y:auto;
  padding:28px 24px;
  animation:tdr-modal-in .25s cubic-bezier(.34,1.2,.64,1);
}
@media(min-width:600px){.tdr-modal{padding:36px 40px}}
@keyframes tdr-modal-in{
  0%{transform:scale(.9) translateY(20px);opacity:0}
  100%{transform:scale(1) translateY(0);opacity:1}
}
.tdr-modal-head{
  display:flex;align-items:flex-start;
  justify-content:space-between;gap:12px;
  margin-bottom:20px;
}
.tdr-modal-head h3{
  font-family:'Noto Serif Bengali',serif;
  font-size:clamp(16px,4vw,20px);
  color:var(--dark);line-height:1.35;
}
.tdr-modal-close{
  width:32px;height:32px;border-radius:50%;
  background:var(--mint);border:none;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;flex-shrink:0;
  transition:background .15s;
}
.tdr-modal-close:hover{background:var(--lt)}
.tdr-modal-close svg{width:16px;height:16px;stroke:var(--ink2);fill:none;stroke-width:2;stroke-linecap:round}
.tdr-adv-list{display:flex;flex-direction:column;gap:12px}
.tdr-adv-item{
  display:flex;align-items:flex-start;gap:12px;
  padding:14px 16px;
  background:var(--mint);
  border-radius:12px;
  border-left:3px solid var(--teal);
}
.tdr-adv-icon{
  width:36px;height:36px;flex-shrink:0;
  background:var(--deep);border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:16px;
}
.tdr-adv-text strong{
  display:block;font-size:13.5px;
  font-weight:600;color:var(--ink);margin-bottom:3px;
}
.tdr-adv-text span{font-size:12.5px;color:var(--ink3);line-height:1.5}
</style>

<div id="tdr-outer">

  <!-- HERO -->
  <div class="tdr-hero">
    <div class="tdr-lang-wrap">
      <button class="tdr-lang-btn" id="tdr-lang-btn" onclick="tdrToggleLang()">
        <span class="tdr-lang-flag">🇬🇧</span>
        <span id="tdr-lang-label">English</span>
      </button>
    </div>
    <div class="tdr-hero-inner">
      <div class="tdr-hero-left">
        <div class="tdr-badge"><span class="tdr-badge-dot"></span>Tangram Technology Limited</div>
        <h1 data-bn="ডিলার আবেদন ফর্ম" data-en="Dealer Application Form">ডিলার আবেদন ফর্ম</h1>
        <p data-bn="ট্যানগ্রাম টেকনোলজি লিমিটেডের অনুমোদিত ডিলার হতে আগ্রহী হলে অনুগ্রহ করে নিচের ফর্মটি সঠিক তথ্য দিয়ে পূরণ করুন। আমাদের টিম আপনার আবেদন পর্যালোচনা করে শীঘ্রই যোগাযোগ করবে।" data-en="If you are interested in becoming an authorized dealer of Tangram Technology Limited, please fill out the form below with accurate information. Our team will review your application and contact you shortly.">ট্যানগ্রাম টেকনোলজি লিমিটেডের অনুমোদিত ডিলার হতে আগ্রহী হলে অনুগ্রহ করে নিচের ফর্মটি সঠিক তথ্য দিয়ে পূরণ করুন। আমাদের টিম আপনার আবেদন পর্যালোচনা করে শীঘ্রই যোগাযোগ করবে।</p>
        <div class="tdr-hero-bar"></div>
      </div>
    </div>
  </div>

  <!-- FORM -->
  <div id="tdr-wrap">
    <form id="tdr-form" novalidate>

      <!-- ১. ব্যক্তিগত তথ্য -->
      <div class="tdr-section">
        <div class="tdr-sec-head">
          <div class="tdr-sec-num">১</div>
          <div class="tdr-sec-title">ব্যক্তিগত তথ্য</div>
        </div>
        <div class="tdr-sec-body">
          <div class="tdr-grid cols2">
            <div class="tdr-field">
              <label>পূর্ণ নাম <span class="req">*</span></label>
              <input type="text" name="full_name" placeholder="আপনার পূর্ণ নাম লিখুন" autocomplete="name">
            </div>
            <div class="tdr-field">
              <label>মোবাইল নম্বর <span class="req">*</span></label>
              <input type="tel" name="mobile" placeholder="০১XXXXXXXXX" autocomplete="tel">
            </div>
          </div>
        </div>
      </div>

      <!-- ২. ব্যবসার তথ্য -->
      <div class="tdr-section">
        <div class="tdr-sec-head">
          <div class="tdr-sec-num">২</div>
          <div class="tdr-sec-title">ব্যবসার তথ্য</div>
        </div>
        <div class="tdr-sec-body">
          <div class="tdr-grid">
            <div class="tdr-field">
              <label>ব্যবসার নাম / দোকানের নাম <span class="req">*</span></label>
              <input type="text" name="shop_name" placeholder="দোকান বা প্রতিষ্ঠানের নাম">
            </div>
            <div class="tdr-field">
              <label>ব্যবসার ধরণ <span class="req">*</span></label>
              <div class="tdr-opts horiz">
                <label class="tdr-opt"><input type="radio" name="business_type" value="খুচরা দোকান (Retail)"> খুচরা দোকান (Retail)</label>
                <label class="tdr-opt"><input type="radio" name="business_type" value="পাইকারি দোকান (Wholesale)"> পাইকারি দোকান (Wholesale)</label>
                <label class="tdr-opt"><input type="radio" name="business_type" value="ডিস্ট্রিবিউটর"> ডিস্ট্রিবিউটর</label>
                <label class="tdr-opt"><input type="radio" name="business_type" value="অনলাইন বিক্রেতা"> অনলাইন বিক্রেতা</label>
              </div>
            </div>
            <div class="tdr-field">
              <label>কত বছর ধরে ব্যবসা করছেন <span class="req">*</span></label>
              <div class="tdr-opts horiz">
                <label class="tdr-opt"><input type="radio" name="years_in_business" value="১ বছরের কম"> ১ বছরের কম</label>
                <label class="tdr-opt"><input type="radio" name="years_in_business" value="১–৩ বছর"> ১–৩ বছর</label>
                <label class="tdr-opt"><input type="radio" name="years_in_business" value="৩–৫ বছর"> ৩–৫ বছর</label>
                <label class="tdr-opt"><input type="radio" name="years_in_business" value="৫ বছরের বেশি"> ৫ বছরের বেশি</label>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ৩. ব্যবসার অবস্থান -->
      <div class="tdr-section">
        <div class="tdr-sec-head">
          <div class="tdr-sec-num">৩</div>
          <div class="tdr-sec-title">ব্যবসার অবস্থান</div>
        </div>
        <div class="tdr-sec-body">
          <div class="tdr-grid cols2">
            <div class="tdr-field">
              <label>জেলা <span class="req">*</span></label>
              <input type="text" name="district" placeholder="আপনার জেলা">
            </div>
            <div class="tdr-field">
              <label>উপজেলা / এলাকা</label>
              <input type="text" name="upazila" placeholder="উপজেলা বা এলাকার নাম">
            </div>
            <div class="tdr-field tdr-span2">
