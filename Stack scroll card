    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800;900&family=Barlow+Condensed:wght@700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy-deep: #060d1f;
            --navy-mid: #0b1530;
            --navy-card: #0e1c3a;
            --navy-card2: #112040;
            --navy-border: rgba(0, 210, 210, 0.18);
            --cyan: #00d9d9;
            --cyan-light: #4ef0f0;
            --cyan-dim: rgba(0, 217, 217, 0.12);
            --teal: #00b8b8;
            --text-primary: #e8f4f8;
            --text-secondary: #7bafc4;
            --text-muted: #4a7a96;
            --badge-bg: rgba(0, 217, 217, 0.12);
            --badge-border: rgba(0, 217, 217, 0.4);
            --feature-bg: rgba(0, 180, 180, 0.08);
            --feature-border: rgba(0, 217, 217, 0.25);
            --spec-label: #4a9db5;
            --divider: rgba(0, 200, 200, 0.12);
            --btn-grad1: #00c8c8;
            --btn-grad2: #007a8a;
            --shadow-glow: rgba(0, 217, 217, 0.12);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Barlow', sans-serif;
            background: #ffffff;
            color: var(--text-primary);
            overflow-x: hidden;
        }

        /* ──────────────────── STACKED SECTION ──────────────────── */
        .stacked-cards-section {
            position: relative;
            width: 100%;
            min-height: 700vh;
            background: #ffffff;
        }

        .stacked-cards-container {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #ffffff;
            overflow: hidden;
            z-index: 10;
        }

        /* subtle radial bg glow */
        .stacked-cards-container::before {
            content: '';
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 900px; height: 600px;
            background: radial-gradient(ellipse at center,
                rgba(0,200,200,0.04) 0%,
                transparent 70%);
            pointer-events: none;
        }

        /* ──────────────────── CARD ──────────────────── */
        .product-card {
            position: fixed;
            width: 90%;
            max-width: 1160px;
            background: linear-gradient(135deg, #0c1b38 0%, #0a172e 60%, #081424 100%);
            border: none;
            border-radius: 20px;
            padding: 44px 48px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 48px;
            align-items: center;
            box-shadow: none;
            top: 50%; left: 50%;
            transform: translateX(-50%) translateY(calc(-50% + 100px));
            opacity: 0;
            z-index: 1;
            pointer-events: none;
        }

        /* top-right subtle glow blob */
        .product-card::before {
            content: '';
            position: absolute;
            top: -80px; right: -80px;
            width: 380px; height: 380px;
            background: radial-gradient(circle, rgba(0,200,200,0.07) 0%, transparent 65%);
            border-radius: 50%;
            pointer-events: none;
        }

        .product-card:nth-child(1) { z-index: 1; }
        .product-card:nth-child(2) { z-index: 2; }
        .product-card:nth-child(3) { z-index: 3; }
        .product-card:nth-child(4) { z-index: 4; }
        .product-card:nth-child(5) { z-index: 5; }
        .product-card:nth-child(6) { z-index: 6; }
        .product-card:nth-child(7) { z-index: 7; }

        .product-card.active { pointer-events: auto; }

        /* ──────────────────── CARD CONTENT ──────────────────── */
        .card-content {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        /* Badge */
        .card-badge {
            display: inline-block;
            width: fit-content;
            padding: 5px 14px;
            background: var(--badge-bg);
            border: 1px solid var(--badge-border);
            border-radius: 50px;
            font-size: 0.7em;
            font-weight: 700;
            letter-spacing: 1.5px;
            color: var(--cyan);
            text-transform: uppercase;
        }

        /* Title */
        .card-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 3em;
            font-weight: 900;
            line-height: 1.1;
            color: var(--text-primary);
            letter-spacing: -0.5px;
        }

        .card-title .accent {
            color: var(--cyan);
        }

        /* Description */
        .card-description {
            font-size: 0.9em;
            line-height: 1.65;
            color: var(--text-secondary);
            font-weight: 400;
        }

        /* Features grid */
        .card-features {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 2px;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            background: var(--feature-bg);
            border: 1px solid var(--feature-border);
            border-radius: 8px;
        }

        .feature-icon {
            font-size: 1.15em;
            width: 26px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .feature-text {
            font-size: 0.83em;
            font-weight: 600;
            color: var(--text-primary);
            letter-spacing: 0.2px;
        }

        /* Specs */
        .card-specs {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            padding-top: 16px;
            border-top: 1px solid var(--divider);
        }

        .spec-item { display: flex; flex-direction: column; gap: 4px; }

        .spec-label {
            font-size: 0.68em;
            color: var(--spec-label);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
        }

        .spec-value {
            font-size: 1em;
            font-weight: 700;
            color: var(--text-primary);
        }

        /* CTA Button */
        .card-cta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            width: fit-content;
            padding: 12px 28px;
            background: linear-gradient(135deg, var(--btn-grad1) 0%, var(--btn-grad2) 100%);
            border: none;
            border-radius: 8px;
            color: #ffffff;
            font-family: 'Barlow', sans-serif;
            font-size: 0.85em;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: 0 8px 24px rgba(0, 200, 200, 0.25);
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .card-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 32px rgba(0, 200, 200, 0.35);
        }

        .card-cta svg {
            width: 16px; height: 16px;
        }

        /* ──────────────────── IMAGE SIDE ──────────────────── */
        .card-image {
            position: relative;
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
        }

        .image-container {
            position: relative;
            width: 100%;
            height: 380px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle, rgba(0,180,180,0.07) 0%, transparent 65%);
            border-radius: 14px;
            overflow: hidden;
        }

        .product-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            filter: drop-shadow(0 16px 40px rgba(0,160,180,0.2));
        }

        /* ──────────────────── RESPONSIVE ──────────────────── */
        @media (max-width: 900px) {
            .product-card {
                grid-template-columns: 1fr;
                padding: 32px 24px;
                gap: 28px;
            }
            .card-title { font-size: 2.4em; }
            .image-container { height: 300px; }
        }

        @media (max-width: 600px) {
            .product-card {
                width: 96%;
                padding: 22px 16px;
                gap: 20px;
                border-radius: 14px;
            }
            .card-title { font-size: 1.9em; }
            .card-features { grid-template-columns: 1fr; gap: 8px; }
            .card-specs { grid-template-columns: 1fr 1fr; }
            .image-container { height: 240px; }
            .card-cta { width: 100%; justify-content: center; }
        }

        html { scroll-behavior: smooth; }
    </style>
</head>
