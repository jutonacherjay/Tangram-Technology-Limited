        function setupScrollAnimation() {
            const cards = document.querySelectorAll('.product-card');
            const section = document.querySelector('.stacked-cards-section');

            // Set section height = card height * number of cards (so scroll matches exactly)
            function updateSectionHeight() {
                const cardHeight = cards[0] ? cards[0].offsetHeight : window.innerHeight;
                section.style.minHeight = (cardHeight * cards.length + window.innerHeight) + 'px';
            }
            updateSectionHeight();
            window.addEventListener('resize', updateSectionHeight);

            window.addEventListener('scroll', () => {
                const sectionRect = section.getBoundingClientRect();
                const sectionTop = sectionRect.top;
                const sectionHeight = sectionRect.height;
                const viewportHeight = window.innerHeight;

                const progress = (viewportHeight - sectionTop) / (sectionHeight + viewportHeight);
                const normalizedProgress = Math.max(0, Math.min(1, progress));

                const cardCount = cards.length;
                const progressPerCard = 1 / cardCount;

                cards.forEach((card, index) => {
                    const cardStartProgress = index * progressPerCard;
                    const cardEndProgress = (index + 1) * progressPerCard;
                    let cardProgress = 0;

                    if (normalizedProgress >= cardStartProgress) {
                        cardProgress = Math.min(1, (normalizedProgress - cardStartProgress) / progressPerCard);
                    }

                    if (cardProgress > 0) {
                        const easeProgress = easeInOutCubic(cardProgress);
                        const startY = 100;
                        const endY = -50;
                        const currentY = startY + (endY - startY) * easeProgress;
                        card.style.transform = `translateX(-50%) translateY(calc(-50% + ${currentY}px))`;
                        card.style.opacity = easeProgress;
                    }

                    if (normalizedProgress >= cardEndProgress) {
                        card.classList.add('active');
                    } else {
                        card.classList.remove('active');
                    }
                });
            });

            window.dispatchEvent(new Event('scroll'));
        }

        function easeInOutCubic(t) {
            return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
        }

        document.addEventListener('DOMContentLoaded', initializeCards);
    </script>
