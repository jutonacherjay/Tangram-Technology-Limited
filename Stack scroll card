        function initializeCards() {
            const wrapper = document.getElementById('cardsWrapper');

            products.forEach((product, index) => {
                const card = document.createElement('div');
                card.className = 'product-card';
                card.dataset.index = index;

                const specsHTML = product.specs.map(spec => `
                    <div class="spec-item">
                        <div class="spec-label">${spec.label}</div>
                        <div class="spec-value">${spec.value}</div>
                    </div>
                `).join('');

                const featuresHTML = product.features.map(feature => `
                    <div class="feature-item">
                        <div class="feature-icon">${feature.icon}</div>
                        <div class="feature-text">${feature.text}</div>
                    </div>
                `).join('');

                card.innerHTML = `
                    <div class="card-content">
                        <div class="card-badge">${product.badge}</div>
                        <h2 class="card-title">${product.title}</h2>
                        <p class="card-description">${product.description}</p>
                        <div class="card-features">${featuresHTML}</div>
                        <div class="card-specs">${specsHTML}</div>
                        <button class="card-cta" onclick="alert('${product.cta} clicked for ${product.specs[0].value}')">
