<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Categories - Electrical Series</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --mint: #e8f8f5;
            --light-teal: #c8f2ec;
            --soft-teal: #b2ece3;
            --teal: #2ecfb0;
            --deep-teal: #0a9e84;
            --dark-teal: #077d68;
            --dark-text: #1a3a36;
            --border-color: #a0d8d0;
            --hover-color: #7fc5ba;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: white;
            color: var(--dark-text);
            overflow-x: hidden;
            width: 100%;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        html {
            width: 100%;
            height: 100%;
        }

        /* HEADER */
        .header {
            background: linear-gradient(135deg, var(--deep-teal) 0%, var(--teal) 100%);
            padding: 15px 20px;
            text-align: center;
            border-bottom: 3px solid var(--dark-teal);
            animation: slideDown 0.6s ease-out;
            flex-shrink: 0;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header h1 {
            font-size: 1.8rem;
            margin-bottom: 5px;
            color: white;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .header p {
            font-size: 0.8rem;
            color: #e0f5f1;
            font-weight: 500;
        }

        /* MAIN CONTAINER */
        .main-container {
            display: flex;
            flex: 1;
            gap: 0;
            overflow: hidden;
            min-height: 0;
        }

        /* LEFT SIDEBAR - CATEGORIES */
        .sidebar {
            width: 30%;
            background-color: white;
            border-right: 2px solid var(--teal);
            overflow-y: auto;
            padding: 15px;
            animation: slideInLeft 0.6s ease-out 0.2s both;
            flex-shrink: 0;
            min-height: 0;
        }

        @keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .sidebar h3 {
            font-size: 1rem;
            margin-bottom: 12px;
            color: var(--deep-teal);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .category-list {
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .category-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .category-item {
            padding: 12px 12px;
            cursor: pointer;
            border-radius: 6px;
            transition: all 0.3s ease;
            position: relative;
            font-weight: 500;
            color: var(--dark-text);
            font-size: 0.9rem;
        }

        .category-item.main-category {
            padding: 12px 8px;
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--deep-teal);
            cursor: default;
            margin-top: 10px;
            margin-bottom: 0;
        }

        .category-item.sub-category {
            padding-left: 24px;
            font-size: 0.85rem;
            background-color: white;
            max-height: 0;
            overflow: hidden;
            padding-top: 0;
            padding-bottom: 0;
            margin: 0;
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            display: block;
        }

        .category-item.main-category:hover ~ .category-item.sub-category {
            max-height: 50px;
            padding-top: 10px;
            padding-bottom: 10px;
            opacity: 1;
            background-color: var(--mint);
        }

        .category-item.sub-category:hover,
        .category-item.sub-category:hover ~ .category-item.sub-category {
            max-height: 50px;
            padding-top: 10px;
            padding-bottom: 10px;
            opacity: 1;
            background-color: var(--light-teal);
        }

        }

        .category-item.sub-category::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 24px;
            width: calc(100% - 24px);
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--teal), transparent);
            animation: none;
            transition: opacity 0.4s ease;
            opacity: 0;
        }

        .category-item.sub-category:hover::after {
            opacity: 1;
        }

        .category-item.sub-category.active {
            max-height: 50px;
            padding-top: 10px;
            padding-bottom: 10px;
            opacity: 1;
            background-color: var(--teal);
            color: white;
            font-weight: 700;
            box-shadow: inset 0 2px 8px rgba(10, 158, 132, 0.2);
        }

        /* RIGHT CONTENT AREA */
        .content {
            width: 70%;
            padding: 15px;
            overflow-y: auto;
            animation: slideInRight 0.6s ease-out 0.2s both;
            display: flex;
            flex-direction: column;
            flex: 1;
            min-height: 0;
        }

        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .content h2 {
            font-size: 1.3rem;
            margin-bottom: 15px;
            color: var(--dark-text);
            font-weight: 700;
            flex-shrink: 0;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 15px;
            flex: 1;
            overflow-y: auto;
        }

        .product-card {
            background-color: white;
            border: 2px solid var(--teal);
            border-radius: 12px;
            padding: 22px;
            text-align: center;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
            animation: fadeInScale 0.5s ease-out both;
            box-shadow: 0 4px 15px rgba(46, 207, 176, 0.15);
            display: flex;
            flex-direction: column;
            min-height: 380px;
        }

        @keyframes fadeInScale {
            from {
                opacity: 0;
                transform: scale(0.9);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .product-card:nth-child(1) { animation-delay: 0.05s; }
        .product-card:nth-child(2) { animation-delay: 0.1s; }
        .product-card:nth-child(3) { animation-delay: 0.15s; }
        .product-card:nth-child(4) { animation-delay: 0.2s; }
        .product-card:nth-child(5) { animation-delay: 0.25s; }
        .product-card:nth-child(6) { animation-delay: 0.3s; }

        .product-image {
            width: 100%;
            height: 160px;
            margin: 0 auto 18px;
            background: linear-gradient(135deg, var(--teal), var(--deep-teal));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            perspective: 1000px;
            transition: transform 0.4s ease;
            overflow: hidden;
            object-fit: cover;
            flex-shrink: 0;
        }

        .product-card:hover .product-image {
            transform: rotateX(25deg) rotateY(25deg) scale(1.1);
        }

        .product-info {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1;
        }

        .product-name {
            font-size: 1.05rem;
            font-weight: 800;
            margin-bottom: 3px;
            color: var(--dark-text);
            transition: color 0.3s ease;
            line-height: 1.3;
        }

        .product-subtitle {
            font-size: 0.8rem;
            color: var(--teal);
            font-weight: 600;
            margin-bottom: 8px;
            padding-bottom: 8px;
            border-bottom: 2px solid var(--light-teal);
        }

        .product-desc {
            font-size: 0.82rem;
            color: var(--hover-color);
            margin-bottom: 12px;
            min-height: 45px;
            line-height: 1.4;
            flex-grow: 1;
        }

        .product-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 20px 45px rgba(46, 207, 176, 0.3);
            border-color: var(--deep-teal);
        }

        .product-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, transparent 0%, rgba(200, 242, 236, 0.1) 100%);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
        }

        .product-card:hover::before {
            opacity: 1;
        }

        /* PAGINATION */
        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-top: 10px;
            flex-wrap: wrap;
            animation: fadeIn 0.5s ease-out;
            flex-shrink: 0;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .pagination button,
        .pagination span {
            padding: 6px 10px;
            border: 2px solid var(--deep-teal);
            background-color: white;
            color: var(--deep-teal);
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.75rem;
            transition: all 0.3s ease;
        }

        .pagination button:hover:not(:disabled) {
            background-color: var(--deep-teal);
            color: white;
            transform: translateY(-1px);
        }

        .pagination button:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .pagination .active {
            background-color: var(--deep-teal);
            color: white;
            font-weight: 700;
        }

        .pagination-left,
        .pagination-center,
        .pagination-right {
            display: flex;
            gap: 6px;
        }

        .pagination-left {
            flex: 0;
        }

        .pagination-center {
            flex: 1;
            justify-content: center;
        }

        .pagination-right {
            flex: 0;
        }

        /* MODAL - PRODUCT DETAILS */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            animation: fadeIn 0.3s ease-out;
        }

        .modal.show {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background-color: white;
            padding: 30px;
            border-radius: 16px;
            width: 90%;
            max-width: 550px;
            box-shadow: 0 30px 60px rgba(7, 125, 104, 0.2);
            animation: slideUp 0.4s ease-out;
            max-height: 80vh;
            overflow-y: auto;
            border-top: 4px solid var(--deep-teal);
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
        }

        .modal-title {
            font-size: 1.5rem;
            color: var(--dark-text);
            font-weight: 700;
        }

        .close-btn {
            font-size: 24px;
            font-weight: bold;
            color: var(--teal);
            cursor: pointer;
            border: none;
            background: none;
            padding: 0;
            width: 26px;
            height: 26px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .close-btn:hover {
            color: var(--dark-teal);
            transform: rotate(90deg);
        }

        .modal-image {
            width: 100%;
            height: 250px;
            background: linear-gradient(135deg, var(--teal), var(--deep-teal));
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3.5rem;
            object-fit: cover;
            overflow: hidden;
        }

        .modal-details {
            display: grid;
            gap: 12px;
            margin-bottom: 20px;
        }

        .detail-item {
            padding: 12px;
            background-color: var(--mint);
            border-left: 4px solid var(--deep-teal);
            border-radius: 6px;
        }

        .detail-label {
            font-size: 0.8rem;
            color: var(--deep-teal);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            margin-bottom: 4px;
        }

        .detail-value {
            font-size: 0.95rem;
            color: var(--dark-text);
            font-weight: 600;
        }

        .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .btn-close-modal {
            flex: 1;
            padding: 10px 16px;
            border: 2px solid var(--deep-teal);
            background-color: white;
            color: var(--deep-teal);
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        .btn-close-modal:hover {
            background-color: var(--deep-teal);
            color: white;
            transform: translateY(-1px);
        }

        /* RESPONSIVE DESIGN */
        @media (max-width: 1024px) {
            .main-container {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                border-right: none;
                border-bottom: 2px solid var(--teal);
                max-height: 250px;
            }

            .content {
                width: 100%;
            }

            .products-grid {
                grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            }
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 1.6rem;
            }

            .header p {
                font-size: 0.8rem;
            }

            .sidebar {
                max-height: 200px;
            }

            .sidebar h3 {
                font-size: 0.95rem;
            }

            .category-item {
                padding: 10px 10px;
                font-size: 0.85rem;
            }

            .content h2 {
                font-size: 1.4rem;
                margin-bottom: 18px;
            }

            .content {
                padding: 18px;
            }

            .products-grid {
                grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
                gap: 15px;
            }

            .product-card {
                min-height: 350px;
                padding: 16px;
            }

            .product-image {
                height: 130px;
                font-size: 1.8rem;
                margin-bottom: 14px;
            }

            .product-name {
                font-size: 0.95rem;
            }

            .product-subtitle {
                font-size: 0.75rem;
            }

            .product-desc {
                font-size: 0.78rem;
                min-height: 35px;
            }

            .modal-content {
                padding: 28px;
                width: 95%;
            }

            .modal-title {
                font-size: 1.4rem;
            }

            .modal-image {
                height: 240px;
                font-size: 2.8rem;
            }

            .find-products-section h2 {
                font-size: 1.6rem;
                margin-bottom: 18px;
            }

            .slider-product-tag {
                padding: 8px 16px;
                font-size: 0.82rem;
            }

            .slider-btn {
                padding: 8px 16px;
                font-size: 0.82rem;
            }

            .slider-dots {
                gap: 8px;
                margin-top: 16px;
            }

            .dot {
                width: 8px;
                height: 8px;
            }

            .dot.active {
                width: 22px;
            }
        }

        @media (max-width: 480px) {
            .header {
                padding: 18px 12px;
            }

            .header h1 {
                font-size: 1.3rem;
                margin-bottom: 6px;
            }

            .header p {
                font-size: 0.75rem;
            }

            .sidebar {
                max-height: 140px;
                padding: 12px;
            }

            .sidebar h3 {
                font-size: 0.85rem;
                margin-bottom: 10px;
            }

            .category-list {
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .category-group {
                gap: 5px;
            }

            .category-item {
                padding: 8px 10px;
                font-size: 0.8rem;
            }

            .category-item.main-category {
                padding: 8px 6px;
                font-size: 0.85rem;
                margin-top: 8px;
            }

            .content {
                padding: 12px;
            }

            .content h2 {
                font-size: 1.1rem;
                margin-bottom: 12px;
            }

            .products-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
            }

            .product-card {
                min-height: 320px;
                padding: 14px;
            }

            .product-image {
                height: 110px;
                font-size: 1.6rem;
                margin-bottom: 10px;
            }

            .product-name {
                font-size: 0.8rem;
                font-weight: 700;
                line-height: 1.2;
            }

            .product-subtitle {
                font-size: 0.7rem;
                padding-bottom: 6px;
                margin-bottom: 6px;
            }

            .product-desc {
                font-size: 0.7rem;
                min-height: 28px;
                margin-bottom: 8px;
            }

            .pagination {
                gap: 4px;
                margin-top: 15px;
                flex-direction: column;
            }

            .pagination-left,
            .pagination-center,
            .pagination-right {
                width: 100%;
                flex: none;
            }

            .pagination-left {
                text-align: left;
            }

            .pagination-right {
                text-align: right;
            }

            .pagination button,
            .pagination span {
                padding: 6px 8px;
                font-size: 0.7rem;
            }

            .find-products-section {
                padding: 20px 12px;
                margin-bottom: 20px;
            }

            .find-products-section h2 {
                font-size: 1.2rem;
                margin-bottom: 12px;
            }

            .slider-track {
                gap: 8px;
                padding: 8px 0;
            }

            .slider-product-tag {
                padding: 7px 12px;
                font-size: 0.75rem;
            }

            .slider-controls {
                gap: 10px;
                margin-top: 12px;
            }

            .slider-btn {
                padding: 6px 10px;
                font-size: 0.75rem;
                flex: 1;
            }

            .slider-dots {
                gap: 5px;
                margin-top: 10px;
            }

            .dot {
                width: 5px;
                height: 5px;
            }

            .dot.active {
                width: 14px;
            }

            .modal-content {
                padding: 18px;
                width: 95%;
            }

            .modal-title {
                font-size: 1.2rem;
            }

            .modal-image {
                height: 180px;
                font-size: 2.2rem;
            }

            .detail-item {
                padding: 10px;
            }

            .detail-label {
                font-size: 0.7rem;
            }

            .detail-value {
                font-size: 0.85rem;
            }
        }

        /* SCROLLBAR STYLING */
        .sidebar::-webkit-scrollbar,
        .content::-webkit-scrollbar,
        .modal-content::-webkit-scrollbar {
            width: 8px;
        }

        .sidebar::-webkit-scrollbar-track,
        .content::-webkit-scrollbar-track,
        .modal-content::-webkit-scrollbar-track {
            background: white;
        }

        .sidebar::-webkit-scrollbar-thumb,
        .content::-webkit-scrollbar-thumb,
        .modal-content::-webkit-scrollbar-thumb {
            background: var(--teal);
            border-radius: 4px;
        }

        .sidebar::-webkit-scrollbar-thumb:hover,
        .content::-webkit-scrollbar-thumb:hover,
        .modal-content::-webkit-scrollbar-thumb:hover {
            background: var(--deep-teal);
        }

        .empty-message {
            text-align: center;
            padding: 40px 20px;
            color: var(--hover-color);
            font-size: 1.1rem;
        }

        /* FIND OUR PRODUCTS SECTION */
        .find-products-section {
            background: linear-gradient(135deg, var(--mint) 0%, white 100%);
            padding: 20px 20px;
            text-align: center;
            border-bottom: 2px solid var(--teal);
            flex-shrink: 0;
        }

        .find-products-section h2 {
            font-size: 1.5rem;
            color: var(--dark-teal);
            font-weight: 700;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        /* SLIDER STYLES FOR ALL DEVICES */
        .slider-container {
            position: relative;
            max-width: 100%;
            margin: 0 auto;
        }

        .slider-wrapper {
            display: flex;
            overflow: hidden;
            gap: 10px;
            position: relative;
            background: white;
            border-radius: 8px;
            padding: 0 5px;
        }

        .slider-track {
            display: flex;
            gap: 10px;
            transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            padding: 5px 0;
        }

        .slider-product-tag {
            padding: 8px 16px;
            background-color: white;
            border: 2px solid var(--teal);
            color: var(--deep-teal);
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.3s ease;
            white-space: nowrap;
            flex-shrink: 0;
            min-width: fit-content;
        }

        .slider-product-tag:hover {
            background-color: var(--deep-teal);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(10, 158, 132, 0.2);
        }

        /* SLIDER BUTTONS */
        .slider-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 10px;
            gap: 10px;
        }

        .slider-btn {
            padding: 8px 14px;
            border: 2px solid var(--deep-teal);
            background-color: white;
            color: var(--deep-teal);
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.8rem;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }

        .slider-btn:hover:not(:disabled) {
            background-color: var(--deep-teal);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(10, 158, 132, 0.2);
        }

        .slider-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        /* SLIDER DOTS/INDICATORS */
        .slider-dots {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 6px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: var(--light-teal);
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid var(--light-teal);
        }

        .dot:hover {
            background-color: var(--teal);
        }

