        // STATE
        let currentPage = 1;
        let itemsPerPage = 6;
        let currentCategory = null;
        let currentSubcategory = null;
        let displayedProducts = [];

        // INITIALIZATION
        function init() {
            renderAllProductsList();
            renderSidebar();
            document.getElementById('categoryTitle').textContent = 'All Products';
            loadAllProducts();
        }

        // RENDER ALL PRODUCTS LIST (FIND OUR PRODUCTS SECTION)
        function renderAllProductsList() {
            const sliderTrack = document.getElementById('sliderTrack');
            const sliderDots = document.getElementById('sliderDots');
            const sliderPrevBtn = document.getElementById('sliderPrevBtn');
            const sliderNextBtn = document.getElementById('sliderNextBtn');
            
            sliderTrack.innerHTML = '';
            sliderDots.innerHTML = '';
            
            const allProducts = [];
            productsData.categories.forEach(cat => {
                cat.subcategories.forEach(subcat => {
                    subcat.products.forEach(product => {
                        allProducts.push(product);
                    });
                });
            });

            // Create slider items
            allProducts.forEach(product => {
                const tag = document.createElement('div');
                tag.className = 'slider-product-tag';
                tag.textContent = product.name;
                tag.addEventListener('click', () => {
                    openModal(product);
                });
                sliderTrack.appendChild(tag);
            });

            // Slider Configuration
            const itemWidth = 200; // Approximate width of each tag + gap
            const visibleItems = 4;
            let currentSlide = 0;
            const totalSlides = Math.ceil(allProducts.length / visibleItems);

            // Create dots
            for (let i = 0; i < totalSlides; i++) {
                const dot = document.createElement('div');
                dot.className = `dot ${i === 0 ? 'active' : ''}`;
                dot.addEventListener('click', () => {
                    currentSlide = i;
                    updateSlider();
                });
                sliderDots.appendChild(dot);
            }

            function updateSlider() {
                const offset = currentSlide * (itemWidth * visibleItems);
                sliderTrack.style.transform = `translateX(-${offset}px)`;

                // Update dots
                document.querySelectorAll('.dot').forEach((dot, index) => {
                    dot.classList.toggle('active', index === currentSlide);
                });

                // Update button states
                sliderPrevBtn.disabled = currentSlide === 0;
                sliderNextBtn.disabled = currentSlide === totalSlides - 1;
            }

            sliderPrevBtn.addEventListener('click', () => {
                if (currentSlide > 0) {
                    currentSlide--;
                    updateSlider();
                }
            });

            sliderNextBtn.addEventListener('click', () => {
                if (currentSlide < totalSlides - 1) {
                    currentSlide++;
                    updateSlider();
                }
            });

            // Initialize
            updateSlider();
        }

        // RENDER SIDEBAR WITH SUBCATEGORIES
        function renderSidebar() {
            const sidebar = document.getElementById('categoryList');
            sidebar.innerHTML = '';
            
            productsData.categories.forEach(cat => {
                // Create a wrapper for each category and its subcategories
                const wrapper = document.createElement('div');
                wrapper.className = 'category-group';
                
                // Main category item
                const catItem = document.createElement('div');
                catItem.className = 'category-item main-category';
                catItem.innerHTML = `<strong>${cat.icon} ${cat.name}</strong>`;
                wrapper.appendChild(catItem);
                
                // Subcategories
                cat.subcategories.forEach(subcat => {
                    const subItem = document.createElement('div');
                    subItem.className = 'category-item sub-category';
                    subItem.textContent = `-- ${subcat.name}`;
                    subItem.dataset.categoryId = cat.id;
                    subItem.dataset.subcategoryId = subcat.id;
                    subItem.addEventListener('click', () => {
                        document.querySelectorAll('.category-item').forEach(i => i.classList.remove('active'));
                        subItem.classList.add('active');
                        currentCategory = cat.id;
                        currentSubcategory = subcat.id;
                        currentPage = 1;
                        displayedProducts = subcat.products;
                        renderProducts();
                        document.getElementById('categoryTitle').textContent = `${cat.name} - ${subcat.name}`;
                    });
                    wrapper.appendChild(subItem);
                });
                
                sidebar.appendChild(wrapper);
            });
        }

        // LOAD ALL PRODUCTS
        function loadAllProducts() {
            displayedProducts = [];
            productsData.categories.forEach(cat => {
                cat.subcategories.forEach(subcat => {
                    displayedProducts.push(...subcat.products);
                });
            });
            currentPage = 1;
            renderProducts();
        }

        // RENDER PRODUCTS
        function renderProducts() {
            const grid = document.getElementById('productsGrid');
            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;
            const paginatedProducts = displayedProducts.slice(startIndex, endIndex);

            grid.innerHTML = '';
            
            if (paginatedProducts.length === 0) {
                grid.innerHTML = '<div class="empty-message">No products found</div>';
            } else {
                paginatedProducts.forEach(product => {
                    const card = document.createElement('div');
                    card.className = 'product-card';
                    
                    // Get subcategory name for subtitle
                    let subcategoryName = '';
                    productsData.categories.forEach(cat => {
                        cat.subcategories.forEach(subcat => {
                            if (subcat.products.includes(product)) {
                                subcategoryName = subcat.name;
                            }
                        });
                    });
                    
                    card.innerHTML = `
                        <img class="product-image" src="${product.image}" alt="${product.name}" onerror="this.style.background='linear-gradient(135deg, #2ecfb0, #0a9e84)'">
                        <div class="product-info">
                            <div class="product-name">${product.name}</div>
                            <div class="product-subtitle">${subcategoryName}</div>
                            <div class="product-desc">${product.description}</div>
                        </div>
                    `;
                    card.addEventListener('click', () => openModal(product));
                    grid.appendChild(card);
                });
            }

            renderPagination();
        }

        // RENDER PAGINATION
        function renderPagination() {
            const paginationLeft = document.getElementById('paginationLeft');
            const paginationCenter = document.getElementById('paginationCenter');
            const paginationRight = document.getElementById('paginationRight');
            
            paginationLeft.innerHTML = '';
            paginationCenter.innerHTML = '';
            paginationRight.innerHTML = '';
            
            const totalPages = Math.ceil(displayedProducts.length / itemsPerPage);

            if (totalPages <= 0) return;

            // Previous Button (LEFT)
            const prevBtn = document.createElement('button');
            prevBtn.textContent = '← Previous';
            prevBtn.disabled = currentPage === 1;
            prevBtn.style.padding = '10px 14px';
            prevBtn.style.border = '2px solid var(--deep-teal)';
            prevBtn.style.backgroundColor = 'white';
            prevBtn.style.color = 'var(--deep-teal)';
            prevBtn.style.borderRadius = '8px';
            prevBtn.style.cursor = 'pointer';
            prevBtn.style.fontWeight = '600';
            prevBtn.style.fontSize = '0.9rem';
            prevBtn.style.transition = 'all 0.3s ease';
            prevBtn.addEventListener('click', () => {
                if (currentPage > 1) {
                    currentPage--;
                    renderProducts();
                    document.querySelector('.content').scrollTop = 0;
                }
            });
            prevBtn.addEventListener('mouseover', function() {
                if (!this.disabled) {
                    this.style.backgroundColor = 'var(--deep-teal)';
                    this.style.color = 'white';
                    this.style.transform = 'translateY(-2px)';
                }
            });
            prevBtn.addEventListener('mouseout', function() {
                if (!this.disabled) {
                    this.style.backgroundColor = 'white';
                    this.style.color = 'var(--deep-teal)';
                    this.style.transform = 'translateY(0)';
                }
            });
            if (currentPage > 1) {
                paginationLeft.appendChild(prevBtn);
            }

            // Page Numbers (CENTER)
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                    const pageBtn = document.createElement('button');
                    pageBtn.textContent = i;
                    pageBtn.style.padding = '10px 14px';
                    pageBtn.style.border = '2px solid var(--deep-teal)';
                    pageBtn.style.backgroundColor = currentPage === i ? 'var(--deep-teal)' : 'white';
                    pageBtn.style.color = currentPage === i ? 'white' : 'var(--deep-teal)';
                    pageBtn.style.borderRadius = '8px';
                    pageBtn.style.cursor = 'pointer';
                    pageBtn.style.fontWeight = '600';
                    pageBtn.style.fontSize = '0.9rem';
                    pageBtn.style.transition = 'all 0.3s ease';
                    
                    if (currentPage === i) {
                        pageBtn.style.fontWeight = '700';
                    }
                    
                    pageBtn.addEventListener('click', () => {
                        currentPage = i;
                        renderProducts();
                        document.querySelector('.content').scrollTop = 0;
                    });
                    pageBtn.addEventListener('mouseover', function() {
                        if (currentPage !== i) {
                            this.style.backgroundColor = 'var(--deep-teal)';
                            this.style.color = 'white';
                            this.style.transform = 'translateY(-2px)';
                        }
                    });
                    pageBtn.addEventListener('mouseout', function() {
                        if (currentPage !== i) {
                            this.style.backgroundColor = 'white';
                            this.style.color = 'var(--deep-teal)';
                            this.style.transform = 'translateY(0)';
                        }
                    });
                    paginationCenter.appendChild(pageBtn);
                }
            }

            // Next Button (RIGHT)
            const nextBtn = document.createElement('button');
            nextBtn.textContent = 'Next →';
            nextBtn.disabled = currentPage === totalPages;
            nextBtn.style.padding = '10px 14px';
            nextBtn.style.border = '2px solid var(--deep-teal)';
            nextBtn.style.backgroundColor = 'white';
            nextBtn.style.color = 'var(--deep-teal)';
            nextBtn.style.borderRadius = '8px';
            nextBtn.style.cursor = 'pointer';
            nextBtn.style.fontWeight = '600';
            nextBtn.style.fontSize = '0.9rem';
            nextBtn.style.transition = 'all 0.3s ease';
            nextBtn.addEventListener('click', () => {
                if (currentPage < totalPages) {
                    currentPage++;
                    renderProducts();
                    document.querySelector('.content').scrollTop = 0;
                }
            });
            nextBtn.addEventListener('mouseover', function() {
                if (!this.disabled) {
                    this.style.backgroundColor = 'var(--deep-teal)';
                    this.style.color = 'white';
                    this.style.transform = 'translateY(-2px)';
                }
            });
            nextBtn.addEventListener('mouseout', function() {
                if (!this.disabled) {
                    this.style.backgroundColor = 'white';
                    this.style.color = 'var(--deep-teal)';
                    this.style.transform = 'translateY(0)';
                }
            });
            if (currentPage < totalPages) {
                paginationRight.appendChild(nextBtn);
            }
        }

        // OPEN PRODUCT DETAILS MODAL
        function openModal(product) {
            const modal = document.getElementById('productModal');
            document.getElementById('modalProductName').textContent = product.name;
            document.getElementById('modalProductImage').src = product.image;
            
            const detailsContainer = document.getElementById('modalDetails');
            detailsContainer.innerHTML = '';
            
            // Add specifications
            Object.entries(product.specifications).forEach(([key, value]) => {
                const item = document.createElement('div');
                item.className = 'detail-item';
                item.innerHTML = `
                    <div class="detail-label">${key}</div>
                    <div class="detail-value">${value}</div>
                `;
                detailsContainer.appendChild(item);
            });
            
            modal.classList.add('show');
            document.body.style.overflow = 'hidden';
        }

        // CLOSE MODAL
        function closeModal() {
            const modal = document.getElementById('productModal');
            modal.classList.remove('show');
            document.body.style.overflow = 'auto';
        }

        // CLOSE MODAL ON BACKGROUND CLICK
        document.getElementById('productModal').addEventListener('click', (e) => {
            if (e.target.id === 'productModal') {
                closeModal();
            }
        });

        // KEYBOARD CLOSE
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeModal();
            }
        });

        // START
        init();
    </script>
</body>
</html>
